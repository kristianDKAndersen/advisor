{
  "env": {
    "CLAUDE_CODE_DISABLE_ADAPTIVE_THINKING": "1",
    "CLAUDE_CODE_DISABLE_AUTO_MEMORY": "1",
    "CLAUDE_CODE_SUBAGENT_MODEL": "sonnet",
    "CLAUDE_CODE_NO_FLICKER": "1"
  },
  "permissions": {
    "allow": [
      "WebFetch",
      "WebSearch",
      "Read",
      "Glob",
      "Grep",
      "Bash(node *)",
      "Bash(bin/summon *)",
      "Bash(bash bin/summon *)",
      "Bash(chmod *)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node $CLAUDE_PROJECT_DIR/.claude/hooks/session-start.js"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node $CLAUDE_PROJECT_DIR/.claude/hooks/workspace-guard.js"
          },
          {
            "type": "command",
            "command": "node $CLAUDE_PROJECT_DIR/lib/hooks/agents-md-context.js"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node $CLAUDE_PROJECT_DIR/lib/hooks/agents-md-lint.js --commit-gate"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"const a=process.env.CLAUDE_TOOL_INPUT||''; if(!a.includes('channel.js')&&!a.includes('synthesize'))process.exit(0); const m=a.match(/--sid\\s+(\\S+)/); const q=a.match(/--seq\\s+(\\S+)/); const nx=a.match(/--next\\s+'([^']+)'/); if(!m||!q)process.exit(0); const {updateSessionState}=require('$CLAUDE_PROJECT_DIR/lib/session'); updateSessionState(m[1],s=>({...s,next_action:(nx&&nx[1])||s.next_action}));\""
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node $CLAUDE_PROJECT_DIR/.claude/hooks/test-on-edit.js"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node $CLAUDE_PROJECT_DIR/.claude/hooks/stop-telemetry.js"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "git -C \"$PWD\" add -A && git -C \"$PWD\" diff --cached --quiet || git -C \"$PWD\" commit -m \"auto-save: pre-compaction checkpoint\" --no-verify 2>/dev/null || true"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/statusline.sh",
    "padding": 1
  },
  "effortLevel": "high",
  "agent": "Advisor",
  "thinking": {
    "enabled": true
  }
}
