#!/usr/bin/env node
// advisor-cost — per-session token usage and estimated cost.
//
// Usage:
//   advisor-cost [--sid <uuid>] [--last N] [--by-agent] [--help]
//
// Reads ~/.advisor/state/token-usage.jsonl (cumulative snapshots — takes last per sid).
// Lines are Claude Code session UUIDs — no join to runs/meta.json is possible.
// --by-agent reads optional ~/.advisor/state/session-map.jsonl {run_sid,claude_uuid,agent}.
// Override state path with ADVISOR_STATE_DIR for testing.
//
// Pricing: cache_read and cache_creation are priced at published discounted rates,
// not excluded — they are real costs. Source: Anthropic pricing page 2026-06.

const fs = require('fs');
const path = require('path');
const os = require('os');

// Price per million tokens, USD.
// cache_read  = 10% of input rate (prompt cache read)
// cache_creation = 125% of input rate (prompt cache write)
const PRICE_TABLE = {
  'claude-haiku':  { input: 0.80,  output: 4.00,  cache_read: 0.08, cache_creation: 1.00  },
  'claude-sonnet': { input: 3.00,  output: 15.00, cache_read: 0.30, cache_creation: 3.75  },
  'claude-opus':   { input: 15.00, output: 75.00, cache_read: 1.50, cache_creation: 18.75 },
  'claude-fable':  { input: 3.00,  output: 15.00, cache_read: 0.30, cache_creation: 3.75  },
};
const DEFAULT_PRICE = { input: 3.00, output: 15.00, cache_read: 0.30, cache_creation: 3.75 };

function priceForModel(modelId) {
  if (!modelId) return { ...DEFAULT_PRICE };
  for (const [prefix, rates] of Object.entries(PRICE_TABLE)) {
    if (modelId.startsWith(prefix)) return { ...rates };
  }
  return { ...DEFAULT_PRICE };
}

function stateDir() {
  return process.env.ADVISOR_STATE_DIR ||
    path.join(os.homedir(), '.advisor', 'state');
}

function readTokenUsage(stDir) {
  const p = path.join(stDir, 'token-usage.jsonl');
  if (!fs.existsSync(p)) return [];
  const lines = fs.readFileSync(p, 'utf8').split('\n');
  const out = [];
  for (const line of lines) {
    if (!line.trim()) continue;
    try { out.push(JSON.parse(line)); } catch (_) {}
  }
  return out;
}

// Take last snapshot per sid; result preserves last-seen order (most-recently-active last).
function lastPerSid(entries) {
  const map = new Map();
  for (const e of entries) {
    if (!e.sid) continue;
    if (map.has(e.sid)) map.delete(e.sid); // re-insert at end to track last-seen position
    map.set(e.sid, e);
  }
  return [...map.values()];
}

function normalizeEntry(e) {
  if (e.breakdown) {
    return {
      sid: e.sid,
      input_tokens: e.breakdown.input_tokens || 0,
      output_tokens: e.breakdown.output_tokens || 0,
      cache_read: e.breakdown.cache_read_input_tokens || 0,
      cache_creation: e.breakdown.cache_creation_input_tokens || 0,
      total: e.total_used || 0,
      ts: e.ts || null,
    };
  }
  return {
    sid: e.sid,
    input_tokens: e.input_tokens || 0,
    output_tokens: e.output_tokens || 0,
    cache_read: e.cache_read || 0,
    cache_creation: e.cache_creation || 0,
    total: e.total || 0,
    ts: e.ts || null,
  };
}

// Reads optional session-map.jsonl {run_sid, claude_uuid, agent}.
// Returns Map<claude_uuid, agent> or null when file absent or empty.
function readSessionMap(stDir) {
  const p = path.join(stDir, 'session-map.jsonl');
  if (!fs.existsSync(p)) return null;
  const lines = fs.readFileSync(p, 'utf8').split('\n');
  const map = new Map();
  for (const line of lines) {
    if (!line.trim()) continue;
    try {
      const e = JSON.parse(line);
      if (e.claude_uuid && e.agent) map.set(e.claude_uuid, e.agent);
    } catch (_) {}
  }
  return map.size > 0 ? map : null;
}

// Cache-aware cost. 5 params; modelId optional (falls back to sonnet rates).
function estimateCost(input_tokens, output_tokens, cache_read, cache_creation, modelId) {
  const r = priceForModel(modelId);
  return (
    (input_tokens   / 1_000_000) * r.input +
    (output_tokens  / 1_000_000) * r.output +
    (cache_read     / 1_000_000) * r.cache_read +
    (cache_creation / 1_000_000) * r.cache_creation
  );
}

// Returns {rows, noMap}.
// noMap=true means --by-agent was requested but session-map.jsonl absent — caller prints note.
function buildRows({ stateDirectory, sidFilter, lastN, byAgent } = {}) {
  const sd = stateDirectory || stateDir();

  const raw = readTokenUsage(sd);
  let sessions = lastPerSid(raw); // last-seen order, oldest→newest

  if (sidFilter) sessions = sessions.filter(e => e.sid === sidFilter);
  if (lastN) sessions = sessions.slice(-lastN); // most recent N by file position

  // reverse for display: newest first
  sessions = [...sessions].reverse();

  const rows = sessions.map(e => {
    const n = normalizeEntry(e);
    const cost = estimateCost(n.input_tokens, n.output_tokens, n.cache_read, n.cache_creation, null);
    return {
      sid: n.sid,
      input: n.input_tokens,
      output: n.output_tokens,
      cache_read: n.cache_read,
      cache_creation: n.cache_creation,
      total: n.total,
      cost,
    };
  });

  if (byAgent) {
    const sessionMap = readSessionMap(sd);
    if (!sessionMap) return { rows: [], noMap: true };

    const agents = new Map();
    for (const r of rows) {
      const agent = sessionMap.get(r.sid) || 'unknown';
      if (!agents.has(agent)) {
        agents.set(agent, { agent, input: 0, output: 0, cache_read: 0, cache_creation: 0, cost: 0, count: 0 });
      }
      const a = agents.get(agent);
      a.input       += r.input;
      a.output      += r.output;
      a.cache_read  += r.cache_read;
      a.cache_creation += r.cache_creation;
      a.cost        += r.cost;
      a.count++;
    }
    return { rows: [...agents.values()].sort((a, b) => b.cost - a.cost), noMap: false };
  }

  return { rows, noMap: false };
}

function fmt(n) { return Number(n).toLocaleString(); }
function fmtCost(c) { return '$' + Number(c).toFixed(4); }
function pad(s, n) { return String(s).slice(0, n).padEnd(n); }

function printTable({ rows, noMap }, byAgent) {
  if (noMap) {
    console.log('session-map not populated yet — per-agent cost unavailable; run more sessions after the worker-session-map hook ships.');
    return;
  }
  if (rows.length === 0) {
    console.log('No sessions found.');
    return;
  }

  if (byAgent) {
    console.log(pad('AGENT', 16) + pad('INPUT', 12) + pad('OUTPUT', 12) + pad('CACHE_READ', 12) + pad('CACHE_WR', 12) + pad('EST COST', 12) + 'SESSIONS');
    console.log('─'.repeat(88));
    for (const r of rows) {
      console.log(pad(r.agent, 16) + pad(fmt(r.input), 12) + pad(fmt(r.output), 12) + pad(fmt(r.cache_read), 12) + pad(fmt(r.cache_creation), 12) + pad(fmtCost(r.cost), 12) + r.count);
    }
    const totInput = rows.reduce((s, r) => s + r.input, 0);
    const totOutput = rows.reduce((s, r) => s + r.output, 0);
    const totRead = rows.reduce((s, r) => s + r.cache_read, 0);
    const totWr = rows.reduce((s, r) => s + r.cache_creation, 0);
    const totCost = rows.reduce((s, r) => s + r.cost, 0);
    const totCount = rows.reduce((s, r) => s + r.count, 0);
    console.log('─'.repeat(88));
    console.log(pad('TOTAL', 16) + pad(fmt(totInput), 12) + pad(fmt(totOutput), 12) + pad(fmt(totRead), 12) + pad(fmt(totWr), 12) + pad(fmtCost(totCost), 12) + totCount);
  } else {
    console.log(pad('SID', 38) + pad('INPUT', 12) + pad('OUTPUT', 12) + pad('CACHE_READ', 12) + pad('CACHE_WR', 12) + 'EST COST');
    console.log('─'.repeat(92));
    for (const r of rows) {
      console.log(pad(r.sid, 38) + pad(fmt(r.input), 12) + pad(fmt(r.output), 12) + pad(fmt(r.cache_read), 12) + pad(fmt(r.cache_creation), 12) + fmtCost(r.cost));
    }
    const totInput = rows.reduce((s, r) => s + r.input, 0);
    const totOutput = rows.reduce((s, r) => s + r.output, 0);
    const totRead = rows.reduce((s, r) => s + r.cache_read, 0);
    const totWr = rows.reduce((s, r) => s + r.cache_creation, 0);
    const totCost = rows.reduce((s, r) => s + r.cost, 0);
    console.log('─'.repeat(92));
    console.log(pad('TOTAL', 38) + pad(fmt(totInput), 12) + pad(fmt(totOutput), 12) + pad(fmt(totRead), 12) + pad(fmt(totWr), 12) + fmtCost(totCost));
  }
  console.log('\nPricing (per MTok): haiku $0.80in/$4.00out/$0.08cr/$1.00cw  sonnet $3.00in/$15.00out/$0.30cr/$3.75cw  opus $15.00in/$75.00out/$1.50cr/$18.75cw');
  console.log('cr=cache_read  cw=cache_creation  fable assumed sonnet rates  default: sonnet');
}

function parseArgs(argv) {
  const out = {};
  for (let i = 0; i < argv.length; i++) {
    const a = argv[i];
    if (a === '--help' || a === '-h') { out.help = true; continue; }
    if (a.startsWith('--')) {
      const k = a.slice(2);
      const next = argv[i + 1];
      if (next !== undefined && !next.startsWith('--')) { out[k] = next; i++; }
      else out[k] = true;
    }
  }
  return out;
}

function main() {
  const args = parseArgs(process.argv.slice(2));
  if (args.help) {
    process.stdout.write(`advisor-cost [--sid <uuid>] [--last N] [--by-agent]

Show estimated API cost per session from ~/.advisor/state/token-usage.jsonl.
All sessions are shown — no filtering (no meta.json join).

Options:
  --sid <uuid>  Show only this session UUID
  --last N      Show only the N most recent sessions (by file order)
  --by-agent    Aggregate by agent name (requires session-map.jsonl)

--by-agent reads ~/.advisor/state/session-map.jsonl with lines:
  {"run_sid":"<run-sid>","claude_uuid":"<uuid>","agent":"<name>"}
If the file is absent or empty, a note is printed and no table is shown.
The session-map writer (worker-session-map hook) must ship first.

Pricing (per million tokens):
  Model         input    output   cache_read  cache_creation
  haiku         $0.80    $4.00    $0.08       $1.00
  sonnet        $3.00    $15.00   $0.30       $3.75
  opus          $15.00   $75.00   $1.50       $18.75
  fable         $3.00    $15.00   $0.30       $3.75  (assumed sonnet family)
  default       $3.00    $15.00   $0.30       $3.75  (sonnet, when model unknown)

Model is not stored in token-usage.jsonl; sonnet rates are the default.
Set ADVISOR_STATE_DIR to override ~/.advisor/state.
`);
    process.exit(0);
  }

  const result = buildRows({
    sidFilter: args.sid || null,
    lastN: args.last ? parseInt(args.last, 10) : null,
    byAgent: !!args['by-agent'],
  });

  printTable(result, !!args['by-agent']);
}

module.exports = { buildRows, estimateCost, priceForModel, lastPerSid, normalizeEntry, readTokenUsage, readSessionMap };
if (require.main === module) main();
