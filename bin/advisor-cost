#!/usr/bin/env node
// advisor-cost — per-session token usage and estimated cost.
//
// Usage:
//   advisor-cost [--sid <sid>] [--last N] [--by-agent] [--help]
//
// Reads ~/.advisor/state/token-usage.jsonl (cumulative snapshots — takes last per sid).
// Joins to meta.json for agent name. Excludes isTestSession runs and sids with no meta.
// Override paths with ADVISOR_STATE_DIR and ADVISOR_RUNS_ROOT for testing.

const fs = require('fs');
const path = require('path');
const os = require('os');

// Price per million tokens, USD. Keyed by model family prefix.
// Source: Anthropic published rates as of 2026-06; no per-token data in intelligence-map.json.
// cache_read and cache_creation tokens are excluded from cost — they dominate total_used but
// pricing them at full input rates would dramatically overstate cost.
const PRICE_TABLE = {
  'claude-haiku':  { input: 0.80,  output: 4.00  },
  'claude-sonnet': { input: 3.00,  output: 15.00 },
  'claude-opus':   { input: 15.00, output: 75.00 },
  'claude-fable':  { input: 3.00,  output: 15.00 }, // no published price — assumed sonnet family
};
const DEFAULT_PRICE = { input: 3.00, output: 15.00 };

function priceForModel(modelId) {
  if (!modelId) return { ...DEFAULT_PRICE };
  for (const [prefix, rates] of Object.entries(PRICE_TABLE)) {
    if (modelId.startsWith(prefix)) return { ...rates };
  }
  return { ...DEFAULT_PRICE };
}

function stateDir() {
  return process.env.ADVISOR_STATE_DIR ||
    path.join(os.homedir(), '.advisor', 'state');
}

function runsRoot() {
  return process.env.ADVISOR_RUNS_ROOT ||
    path.join(os.homedir(), '.advisor', 'runs');
}

function readTokenUsage(stDir) {
  const p = path.join(stDir, 'token-usage.jsonl');
  if (!fs.existsSync(p)) return [];
  const lines = fs.readFileSync(p, 'utf8').split('\n');
  const out = [];
  for (const line of lines) {
    if (!line.trim()) continue;
    try { out.push(JSON.parse(line)); } catch (_) {}
  }
  return out;
}

// Token-usage entries are cumulative snapshots — take last per sid, not sum.
function lastPerSid(entries) {
  const map = new Map();
  for (const e of entries) {
    if (!e.sid) continue;
    map.set(e.sid, e);
  }
  return [...map.values()];
}

function normalizeEntry(e) {
  // Support both formats:
  //   {sid, total_used, breakdown:{input_tokens, output_tokens, cache_read_input_tokens, cache_creation_input_tokens}}
  //   {sid, ts, input_tokens, output_tokens, cache_read, cache_creation, total}
  if (e.breakdown) {
    return {
      sid: e.sid,
      input_tokens: e.breakdown.input_tokens || 0,
      output_tokens: e.breakdown.output_tokens || 0,
      cache_read: e.breakdown.cache_read_input_tokens || 0,
      cache_creation: e.breakdown.cache_creation_input_tokens || 0,
      total: e.total_used || 0,
      ts: e.ts || null,
    };
  }
  return {
    sid: e.sid,
    input_tokens: e.input_tokens || 0,
    output_tokens: e.output_tokens || 0,
    cache_read: e.cache_read || 0,
    cache_creation: e.cache_creation || 0,
    total: e.total || 0,
    ts: e.ts || null,
  };
}

function readMeta(runsDir, sid) {
  const p = path.join(runsDir, sid, 'meta.json');
  if (!fs.existsSync(p)) return null;
  try { return JSON.parse(fs.readFileSync(p, 'utf8')); } catch (_) { return null; }
}

function estimateCost(input_tokens, output_tokens, modelId) {
  const rates = priceForModel(modelId);
  return (input_tokens / 1_000_000) * rates.input + (output_tokens / 1_000_000) * rates.output;
}

function buildRows({ stateDirectory, runsDirectory, sidFilter, lastN, byAgent } = {}) {
  const sd = stateDirectory || stateDir();
  const rd = runsDirectory || runsRoot();

  const raw = readTokenUsage(sd);
  const last = lastPerSid(raw);

  let rows = [];
  for (const e of last) {
    const norm = normalizeEntry(e);
    const meta = readMeta(rd, norm.sid);
    if (!meta) continue; // skip sids with no meta (can't confirm non-test)
    if (meta.isTestSession) continue;
    if (sidFilter && norm.sid !== sidFilter) continue;

    const cost = estimateCost(norm.input_tokens, norm.output_tokens, meta.model);
    rows.push({
      sid: norm.sid,
      agent: meta.agent || '—',
      created_at: meta.created_at || null,
      input: norm.input_tokens,
      output: norm.output_tokens,
      cache_read: norm.cache_read,
      cache_creation: norm.cache_creation,
      total: norm.total,
      cost,
      model: meta.model || null,
    });
  }

  // Sort by created_at desc (newest first), like advisor-list.
  rows.sort((a, b) => {
    if (!a.created_at && !b.created_at) return 0;
    if (!a.created_at) return 1;
    if (!b.created_at) return -1;
    return new Date(b.created_at) - new Date(a.created_at);
  });

  if (lastN) rows = rows.slice(0, lastN);

  if (byAgent) {
    const agents = new Map();
    for (const r of rows) {
      const k = r.agent;
      if (!agents.has(k)) agents.set(k, { agent: k, input: 0, output: 0, cost: 0, count: 0 });
      const a = agents.get(k);
      a.input += r.input;
      a.output += r.output;
      a.cost += r.cost;
      a.count++;
    }
    return [...agents.values()].sort((a, b) => b.cost - a.cost);
  }

  return rows;
}

function fmt(n) { return Number(n).toLocaleString(); }
function fmtCost(c) { return '$' + Number(c).toFixed(4); }
function pad(s, n) { return String(s).slice(0, n).padEnd(n); }

function printTable(rows, byAgent) {
  if (byAgent) {
    console.log(pad('AGENT', 16) + pad('INPUT', 12) + pad('OUTPUT', 12) + pad('EST COST', 12) + 'SESSIONS');
    console.log('─'.repeat(64));
    for (const r of rows) {
      console.log(pad(r.agent, 16) + pad(fmt(r.input), 12) + pad(fmt(r.output), 12) + pad(fmtCost(r.cost), 12) + r.count);
    }
    const totInput = rows.reduce((s, r) => s + r.input, 0);
    const totOutput = rows.reduce((s, r) => s + r.output, 0);
    const totCost = rows.reduce((s, r) => s + r.cost, 0);
    const totCount = rows.reduce((s, r) => s + r.count, 0);
    console.log('─'.repeat(64));
    console.log(pad('TOTAL', 16) + pad(fmt(totInput), 12) + pad(fmt(totOutput), 12) + pad(fmtCost(totCost), 12) + totCount);
  } else {
    console.log(pad('SID', 28) + pad('AGENT', 12) + pad('INPUT', 12) + pad('OUTPUT', 12) + 'EST COST');
    console.log('─'.repeat(76));
    for (const r of rows) {
      console.log(pad(r.sid, 28) + pad(r.agent, 12) + pad(fmt(r.input), 12) + pad(fmt(r.output), 12) + fmtCost(r.cost));
    }
    const totInput = rows.reduce((s, r) => s + r.input, 0);
    const totOutput = rows.reduce((s, r) => s + r.output, 0);
    const totCost = rows.reduce((s, r) => s + r.cost, 0);
    console.log('─'.repeat(76));
    console.log(pad('TOTAL', 28) + pad('', 12) + pad(fmt(totInput), 12) + pad(fmt(totOutput), 12) + fmtCost(totCost));
  }
  console.log('\nPricing: input+output tokens only (cache_read and cache_creation excluded).');
  console.log('Rates/MTok: haiku $0.80in/$4.00out  sonnet $3.00in/$15.00out  opus $15.00in/$75.00out  fable $3.00in/$15.00out(assumed)');
  console.log('Model unknown per-session (not in meta.json); sonnet rates used as default.');
}

function parseArgs(argv) {
  const out = {};
  for (let i = 0; i < argv.length; i++) {
    const a = argv[i];
    if (a === '--help' || a === '-h') { out.help = true; continue; }
    if (a.startsWith('--')) {
      const k = a.slice(2);
      const next = argv[i + 1];
      if (next !== undefined && !next.startsWith('--')) { out[k] = next; i++; }
      else out[k] = true;
    }
  }
  return out;
}

function main() {
  const args = parseArgs(process.argv.slice(2));
  if (args.help) {
    process.stdout.write(`advisor-cost [--sid <sid>] [--last N] [--by-agent]

Show estimated API cost per session from ~/.advisor/state/token-usage.jsonl.
Excludes isTestSession runs and sids with no meta.json.

Options:
  --sid <sid>   Show only this session
  --last N      Show only the N most recent sessions (by created_at)
  --by-agent    Aggregate by agent name

Pricing notes:
  Cost = input_tokens + output_tokens at published Anthropic rates.
  cache_read_input_tokens and cache_creation_input_tokens are EXCLUDED —
  they dominate total_used but pricing at full input rates would overstate cost.
  Per-MTok: haiku $0.80in/$4.00out, sonnet $3.00in/$15.00out,
  opus $15.00in/$75.00out, fable $3.00in/$15.00out (assumed sonnet family).
  Model is not stored in meta.json; sonnet rates are the default.
  Set ADVISOR_STATE_DIR to override ~/.advisor/state.
  Set ADVISOR_RUNS_ROOT to override ~/.advisor/runs.
`);
    process.exit(0);
  }

  const rows = buildRows({
    sidFilter: args.sid || null,
    lastN: args.last ? parseInt(args.last, 10) : null,
    byAgent: !!args['by-agent'],
  });

  if (rows.length === 0) {
    console.log('No sessions found (excluding test sessions and sessions without meta.json).');
    process.exit(0);
  }

  printTable(rows, !!args['by-agent']);
}

module.exports = { buildRows, estimateCost, priceForModel, lastPerSid, normalizeEntry, readTokenUsage };
if (require.main === module) main();
