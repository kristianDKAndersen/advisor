#!/usr/bin/env bash
# close-worker-tab — close the Terminal tab that ran a given worker session.
#
# Usage: close-worker-tab <sid>
#
# Called by the Advisor after receiving a worker's `result` or after sending
# `terminate`. Idempotent — safe if the worker already self-closed its tab.
#
# Supports both Apple Terminal (osascript) and headless tmux sessions.
# For tmux, it looks for any session whose name starts with "advisor-<sid>".

set -u

# shellcheck source=../lib/tab-trace.sh
source "$(dirname "${BASH_SOURCE[0]}")/../lib/tab-trace.sh"

sid="${1:-}"
if [[ -z "$sid" ]]; then _tab_trace no-match -; exit 0; fi

# Resolve runDir: primary location, then repo-local fallback.
runDir="$HOME/.advisor/runs/$sid"
if [[ ! -d "$runDir" ]]; then
  advisorRepo="$(dirname "$(dirname "$0")")"
  runDir="$advisorRepo/.advisor-runs/$sid"
fi
if [[ ! -d "$runDir" ]]; then _tab_trace no-match -; exit 0; fi

# Defense in depth: kill any lingering claude processes whose argv contains sid.
ps -ax -o pid=,comm=,args= 2>/dev/null | while IFS= read -r line; do
  comm_field=$(awk '{print $2}' <<<"$line")
  pid_field=$(awk '{print $1}' <<<"$line")
  if [[ "$comm_field" == "claude" ]] && grep -qF "$sid" <<<"$line"; then
    kill -KILL "$pid_field" 2>/dev/null || true
  fi
done

# ── Headless tmux path ────────────────────────────────────────────────────────
# Look for any tmux session whose name starts with "advisor-<sid>" (covers
# both the old "advisor-<sid>" format and the new "advisor-<sid>-<agent>" format).
if command -v tmux >/dev/null 2>&1; then
  tmux ls -F '#{session_name}' 2>/dev/null | grep "^advisor-${sid}" | while IFS= read -r _sess; do
    _tab_trace tmux-kill "$_sess"
    tmux kill-session -t "$_sess" 2>/dev/null || true
  done
fi

# ── Apple Terminal (TUI) path ─────────────────────────────────────────────────
ttyFile="$runDir/tty.txt"
if [[ ! -f "$ttyFile" ]]; then _tab_trace no-match -; exit 0; fi

myTTY=$(tr -d '[:space:]' < "$ttyFile")
if [[ -z "$myTTY" ]]; then _tab_trace no-tty-noop -; exit 0; fi

if [[ "$(uname)" != "Darwin" ]]; then
  _tab_trace no-match "$myTTY"
  exit 0
fi
if ! command -v osascript >/dev/null 2>&1; then
  _tab_trace no-match "$myTTY"
  exit 0
fi

_tab_trace close-tab "$myTTY"
osascript - "$myTTY" <<'EOF'
on run argv
  set myTTY to item 1 of argv
  tell application "Terminal"
    set found to false
    repeat with w in windows
      try
        repeat with t in tabs of w
          if tty of t is myTTY then
            set found to true
            if (count tabs of w) > 1 then
              close t saving no
            else
              close w saving no
            end if
            exit repeat
          end if
        end repeat
      end try
      if found then exit repeat
    end repeat
  end tell
end run
EOF
