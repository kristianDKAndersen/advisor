#!/usr/bin/env bash
# close-worker-tab — close the Terminal tab that ran a given worker session.
#
# Usage: close-worker-tab <sid>
#
# Called by the Advisor after receiving a worker's `result` or after sending
# `terminate`. Idempotent — safe if the worker already self-closed its tab.
#
# Supports both Apple Terminal (osascript) and headless tmux sessions.
# For tmux, it looks for any session whose name starts with "advisor-<sid>".

set -u

# shellcheck source=../lib/tab-trace.sh
source "$(dirname "${BASH_SOURCE[0]}")/../lib/tab-trace.sh"

sid="${1:-}"
if [[ -z "$sid" ]]; then _tab_trace no-match -; exit 0; fi

# Resolve runDir: primary location, then repo-local fallback.
runDir="$HOME/.advisor/runs/$sid"
if [[ ! -d "$runDir" ]]; then
  advisorRepo="$(dirname "$(dirname "$0")")"
  runDir="$advisorRepo/.advisor-runs/$sid"
fi
if [[ ! -d "$runDir" ]]; then _tab_trace no-match -; exit 0; fi

# Defense in depth: kill any lingering claude processes whose argv contains sid.
ps -ax -o pid=,comm=,args= 2>/dev/null \
  | awk -v sid="$sid" '$2=="claude" && index($0, sid) {print $1}' \
  | xargs -r kill -KILL 2>/dev/null || true

# ── Headless tmux path ────────────────────────────────────────────────────────
# Look for any tmux session whose name starts with "advisor-<sid>" (covers
# both the old "advisor-<sid>" format and the new "advisor-<sid>-<agent>" format).
if command -v tmux >/dev/null 2>&1; then
  # In multiplex mode, first try to kill by the @advisor_sid pane option (covers
  # tui-shared workers and any pane-tagged worker). The pane title is NOT used —
  # the claude TUI overwrites it; @advisor_sid is app-immune. kill-pane cascade
  # removes the window and session when the last pane in the tui window is gone.
  _PANE_KILLED=0
  if [[ "${ADVISOR_TMUX_MULTIPLEX:-}" == "1" ]]; then
    PANE_ID=$(tmux list-panes -s -t advisor -F '#{pane_id} #{@advisor_sid}' 2>/dev/null \
      | awk -v s="$sid" '$2 == s {print $1}' | head -1)
    if [[ -n "$PANE_ID" ]]; then
      _tab_trace tmux-kill-pane "$PANE_ID"
      tmux kill-pane -t "$PANE_ID" 2>/dev/null || true
      _PANE_KILLED=1
    fi
  fi
  if [[ "$_PANE_KILLED" == "0" ]]; then
    WIN_ID=$(tmux list-windows -t advisor -F '#{window_id} #{window_name}' 2>/dev/null \
      | grep -F " ${sid}" | awk '{print $1}' | head -1)
    if [[ -n "$WIN_ID" ]]; then
      _tab_trace tmux-kill "advisor:${WIN_ID}"
      tmux kill-window -t "advisor:${WIN_ID}" 2>/dev/null || true
    else
      # Fallback: old session-per-worker (flag-off path or pre-migration sessions)
      tmux ls -F '#{session_name}' 2>/dev/null | grep "^advisor-${sid}" | while IFS= read -r _sess; do
        _tab_trace tmux-kill "$_sess"
        tmux kill-session -t "$_sess" 2>/dev/null || true
      done
    fi
  fi
fi

# ── Apple Terminal (TUI) path ─────────────────────────────────────────────────
ttyFile="$runDir/tty.txt"
if [[ ! -f "$ttyFile" ]]; then _tab_trace no-match -; exit 0; fi

myTTY=$(tr -d '[:space:]' < "$ttyFile")
if [[ -z "$myTTY" ]]; then _tab_trace no-tty-noop -; exit 0; fi

if [[ "$(uname)" != "Darwin" ]]; then
  _tab_trace no-match "$myTTY"
  exit 0
fi
if ! command -v osascript >/dev/null 2>&1; then
  _tab_trace no-match "$myTTY"
  exit 0
fi

_tab_trace close-tab "$myTTY"
osascript - "$myTTY" <<'EOF'
on run argv
  set myTTY to item 1 of argv
  tell application "Terminal"
    set found to false
    repeat with w in windows
      try
        repeat with t in tabs of w
          if tty of t is myTTY then
            set found to true
            if (count tabs of w) > 1 then
              close t saving no
            else
              close w saving no
            end if
            exit repeat
          end if
        end repeat
      end try
      if found then exit repeat
    end repeat
  end tell
end run
EOF

# ── Worktree cleanup ─────────────────────────────────────────────────────────
# Remove the per-worker git worktree (provisioned by lib/summon.js for coder
# agents on branch ws/<sid>) so the .git/worktrees registry and the branch
# refs don't accumulate. Set ADVISOR_SKIP_WORKTREE_CLEANUP=1 to preserve the
# worktree for post-mortem debugging.
#
# Strategy: just try `git worktree remove` and treat success as proof that
# this was a registered worktree. If the dir exists but isn't a worktree
# (e.g. copyDir-provisioned non-coder workers), the remove fails silently
# and we skip the branch delete. Avoids macOS /var ↔ /private/var symlink
# headaches that a grep-based pre-check would hit.
_cleanup_worktree() {
  [[ "${ADVISOR_SKIP_WORKTREE_CLEANUP:-}" == "1" ]] && return 0
  local advisorRoot workspaceDir
  advisorRoot="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
  workspaceDir="$runDir/workspace"
  [[ -d "$workspaceDir" ]] || return 0
  _tab_trace worktree-remove "$workspaceDir"
  if git -C "$advisorRoot" worktree remove --force "$workspaceDir" 2>/dev/null; then
    git -C "$advisorRoot" branch -D "ws/${sid}" 2>/dev/null || \
      echo "WARN: close-worker-tab: could not delete branch ws/${sid} (orphaned?)" >&2
  fi
}
_cleanup_worktree
