#!/usr/bin/env bash
# close-tab — close the macOS Terminal window that is running this process.
#
# Used by worker sub-agents as their final tool call after receiving a
# `terminate` message from the Advisor. Backgrounds osascript so the shell
# exits immediately before the window closes.
#
# Fails silently on non-macOS or if osascript is unavailable — the worker
# session will still exit when claude quits; the tab just sticks around.

set -u

if [[ "$(uname)" != "Darwin" ]]; then
  exit 0
fi
if ! command -v osascript >/dev/null 2>&1; then
  exit 0
fi

myTTY=$(tty 2>/dev/null) || true
[[ "$myTTY" != /dev/* ]] && { _pt=$(ps -o tty= -p "$PPID" 2>/dev/null | tr -d ' '); [[ "$_pt" =~ ^tty ]] && myTTY="/dev/$_pt"; }
[[ -z "$myTTY" ]] && exit 0   # headless / non-TTY: no-op
osascript - "$myTTY" <<'EOF' &
on run argv
  set myTTY to item 1 of argv
  tell application "Terminal"
    set found to false
    repeat with w in windows
      repeat with t in tabs of w
        if tty of t is myTTY then
          set found to true
          if (count tabs of w) > 1 then
            close t
          else
            close w
          end if
          exit repeat
        end if
      end repeat
      if found then exit repeat
    end repeat
  end tell
end run
EOF
disown 2>/dev/null || true
parent_name=$(ps -o comm= -p $PPID 2>/dev/null | awk -F'/' '{print $NF}')
if [[ "$parent_name" == "claude" || "$parent_name" == "node" ]]; then
  sleep 0.2
  kill -TERM $PPID 2>/dev/null || true
fi
exit
