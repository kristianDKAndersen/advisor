#!/usr/bin/env bash
# close-tab — close the macOS Terminal window that is running this process.
#
# Used by worker sub-agents as their final tool call after receiving a
# `terminate` message from the Advisor. Backgrounds osascript so the shell
# exits immediately before the window closes.
#
# Headless tmux workers: set ADVISOR_TMUX=1 or run inside a tmux session
# whose name matches ^advisor-. In that mode, tmux kill-session is used
# instead of osascript (which only works for Apple Terminal tabs).
#
# Fails silently on non-macOS or if osascript is unavailable — the worker
# session will still exit when claude quits; the tab just sticks around.

set -u

# shellcheck source=../lib/tab-trace.sh
source "$(dirname "${BASH_SOURCE[0]}")/../lib/tab-trace.sh"

# ── Headless tmux path ────────────────────────────────────────────────────────
_is_tmux=0
if [[ "${ADVISOR_TMUX:-}" == "1" ]]; then
  _is_tmux=1
elif [[ -n "${TMUX:-}" ]] && command -v tmux >/dev/null 2>&1; then
  _sess=$(tmux display-message -p '#S' 2>/dev/null || true)
  if [[ "${ADVISOR_TMUX_MULTIPLEX:-}" == "1" ]]; then
    [[ "$_sess" == "advisor" ]] && _is_tmux=1
  else
    [[ "$_sess" =~ ^advisor- ]] && _is_tmux=1
  fi
fi

if [[ "$_is_tmux" == "1" ]]; then
  # Kill parent claude/node process before destroying the session.
  _parent_name=$(ps -o comm= -p $PPID 2>/dev/null | awk -F'/' '{print $NF}')
  if [[ "$_parent_name" == "claude" || "$_parent_name" == "node" ]]; then
    kill -TERM $PPID 2>/dev/null || true
    sleep 0.5
    kill -0 $PPID 2>/dev/null && kill -KILL $PPID 2>/dev/null || true
  fi
  if [[ -n "${TMUX:-}" ]]; then
    if [[ "${ADVISOR_TMUX_MULTIPLEX:-}" == "1" ]]; then
      # Use $TMUX_PANE only. Do NOT fall back to `tmux display-message -p
      # '#{pane_id}'` — that returns the ATTACHED CLIENT's active pane, not
      # this process's own pane, so it can kill an innocent live worker.
      # If $TMUX_PANE is empty, no-op rather than guess.
      _pane="${TMUX_PANE:-}"
      if [[ -n "$_pane" ]]; then
        tmux kill-pane -t "$_pane" 2>/dev/null || true
        _tab_trace tmux-kill -
      else
        _tab_trace no-pane-noop -
      fi
    else
      _sess=$(tmux display-message -p '#S' 2>/dev/null || true)
      if [[ -n "$_sess" ]]; then
        tmux kill-session -t "$_sess" 2>/dev/null || true
        _tab_trace tmux-kill -
      else
        _tab_trace no-match -
      fi
    fi
  else
    _tab_trace no-match -
  fi
  exit 0
fi

# ── Apple Terminal (TUI) path ─────────────────────────────────────────────────
if [[ "$(uname)" != "Darwin" ]]; then
  _tab_trace no-match -
  exit 0
fi
if ! command -v osascript >/dev/null 2>&1; then
  _tab_trace no-match -
  exit 0
fi

myTTY=$(tty 2>/dev/null) || true
[[ "$myTTY" != /dev/* ]] && { _pt=$(ps -o tty= -p "$PPID" 2>/dev/null | tr -d ' '); [[ "$_pt" =~ ^tty ]] && myTTY="/dev/$_pt"; }
if [[ -z "$myTTY" ]]; then _tab_trace no-tty-noop -; exit 0; fi   # headless / non-TTY: no-op
parent_name=$(ps -o comm= -p $PPID 2>/dev/null | awk -F'/' '{print $NF}')
if [[ "$parent_name" == "claude" || "$parent_name" == "node" ]]; then
  kill -TERM $PPID 2>/dev/null || true
  sleep 0.5
  kill -0 $PPID 2>/dev/null && kill -KILL $PPID 2>/dev/null || true
fi
_tab_trace close-tab "$myTTY"
osascript - "$myTTY" <<'EOF' &
on run argv
  set myTTY to item 1 of argv
  tell application "Terminal"
    set found to false
    repeat with w in windows
      try
        repeat with t in tabs of w
          if tty of t is myTTY then
            set found to true
            if (count tabs of w) > 1 then
              close t saving no
            else
              close w saving no
            end if
            exit repeat
          end if
        end repeat
      end try
      if found then exit repeat
    end repeat
  end tell
end run
EOF
disown 2>/dev/null || true
exit
