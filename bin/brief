#!/usr/bin/env bash
# brief — compose and dispatch a worker brief, including tool allowlist.
#
# Usage (inline flags):
#   bin/brief --agent <name> --task "<text>" --goal "<done>" \
#             [--tools "Read,Write,Bash"] [--model <model>] \
#             [--intelligence <0-100>] [--sid <id>]
#
# Usage (brief file):
#   bin/brief --file brief.json
#
# brief.json: { agent, task, goal, tools?, model?, intelligence?, sid? }
#
# When a tools field is present, --allowedTools is appended to the bin/summon
# invocation so the worker's claude session is restricted to that tool set.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

AGENT=""
TASK=""
GOAL=""
TOOLS=""
MODEL=""
INTELLIGENCE=""
SID=""
FILE=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --agent)         AGENT="$2";        shift 2 ;;
    --task)          TASK="$2";         shift 2 ;;
    --goal)          GOAL="$2";         shift 2 ;;
    --tools)         TOOLS="$2";        shift 2 ;;
    --model)         MODEL="$2";        shift 2 ;;
    --intelligence)  INTELLIGENCE="$2"; shift 2 ;;
    --sid)           SID="$2";          shift 2 ;;
    --file)          FILE="$2";         shift 2 ;;
    -h|--help)
      echo "Usage: brief --agent <name> --task \"<text>\" --goal \"<done>\" [--tools \"T1,T2\"] [--model <m>] [--intelligence <0-100>] [--sid <id>]"
      echo "       brief --file brief.json"
      exit 0
      ;;
    *) echo "Unknown flag: $1" >&2; exit 1 ;;
  esac
done

# If --file provided, extract fields with Node; inline flags take precedence.
if [[ -n "$FILE" ]]; then
  _extract() {
    node -e "
try {
  const b = JSON.parse(require('fs').readFileSync(process.argv[1], 'utf8'));
  process.stdout.write(b[process.argv[2]] != null ? String(b[process.argv[2]]) : '');
} catch(e) {}
" -- "$FILE" "$1"
  }
  [[ -z "$AGENT" ]]        && AGENT="$(_extract agent)"
  [[ -z "$TASK" ]]         && TASK="$(_extract task)"
  [[ -z "$GOAL" ]]         && GOAL="$(_extract goal)"
  [[ -z "$TOOLS" ]]        && TOOLS="$(_extract tools)"
  [[ -z "$MODEL" ]]        && MODEL="$(_extract model)"
  [[ -z "$INTELLIGENCE" ]] && INTELLIGENCE="$(_extract intelligence)"
  [[ -z "$SID" ]]          && SID="$(_extract sid)"
fi

if [[ -z "$AGENT" || -z "$TASK" || -z "$GOAL" ]]; then
  echo "Missing required field: --agent, --task, --goal. Run --help for usage." >&2
  exit 1
fi

SUMMON_ARGS=(--agent "$AGENT" --task "$TASK" --goal "$GOAL")
[[ -n "$MODEL" ]]        && SUMMON_ARGS+=(--model        "$MODEL")
[[ -n "$INTELLIGENCE" ]] && SUMMON_ARGS+=(--intelligence "$INTELLIGENCE")
[[ -n "$SID" ]]          && SUMMON_ARGS+=(--sid          "$SID")
[[ -n "$TOOLS" ]]        && SUMMON_ARGS+=(--allowed-tools "$TOOLS")

exec "$ROOT/bin/summon" "${SUMMON_ARGS[@]}"
