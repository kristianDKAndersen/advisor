#!/usr/bin/env node
'use strict';

// advisor-timeline — zero-dependency Node.js HTTP server
// Serves a color-coded SSE timeline of ~/.advisor/runs/<sid>/channel messages.
// Usage: node bin/advisor-timeline [--port <n>]  (default: 7878)

const http = require('http');
const fs = require('fs');
const path = require('path');
const os = require('os');

// ── Config ────────────────────────────────────────────────────────────────────
const RUNS_DIR = path.join(os.homedir(), '.advisor', 'runs');
const CLIENT_DIST = process.env.ADVISOR_CLIENT_DIST || path.join(__dirname, '..', 'client', 'dist');
const CLIENT_DIST_EXISTS = fs.existsSync(path.join(CLIENT_DIST, 'index.html'));

const argv = process.argv.slice(2);
let port = 7878;
for (let i = 0; i < argv.length; i++) {
  if (argv[i] === '--port' && argv[i + 1]) { port = parseInt(argv[i + 1], 10); i++; }
}

// ── JSONL helpers ─────────────────────────────────────────────────────────────
function readJsonl(filePath) {
  if (!fs.existsSync(filePath)) return [];
  const out = [];
  for (const line of fs.readFileSync(filePath, 'utf8').split('\n')) {
    if (!line.trim()) continue;
    try { out.push(JSON.parse(line)); } catch (_) {}
  }
  return out;
}

// ── Session helpers ───────────────────────────────────────────────────────────
function getSessions() {
  if (!fs.existsSync(RUNS_DIR)) return [];
  const nowSec = Date.now() / 1000;
  return fs.readdirSync(RUNS_DIR)
    .filter(name => {
      const p = path.join(RUNS_DIR, name);
      let stat;
      try { stat = fs.statSync(p); } catch { return false; }
      if (!stat.isDirectory()) return false;
      // Skip dirs marked as test sessions
      try {
        const meta = JSON.parse(fs.readFileSync(path.join(p, 'meta.json'), 'utf8'));
        if (meta.isTestSession) return false;
      } catch (_) {}
      // Skip dirs with no worker activity (empty outbox) older than 24h
      let outboxEmpty = true;
      try {
        outboxEmpty = fs.readFileSync(path.join(p, 'channel', 'outbox.jsonl'), 'utf8').trim() === '';
      } catch (_) {}
      if (outboxEmpty) {
        const ageSec = nowSec - stat.mtimeMs / 1000;
        if (ageSec > 24 * 3600) return false;
      }
      return true;
    })
    .sort()
    .reverse();
}

function getMessages(sid) {
  const dir = path.join(RUNS_DIR, sid, 'channel');
  const inbox  = readJsonl(path.join(dir, 'inbox.jsonl')).map(m => ({ ...m, _dir: 'in' }));
  const outbox = readJsonl(path.join(dir, 'outbox.jsonl')).map(m => ({ ...m, _dir: 'out' }));
  return [...inbox, ...outbox].sort((a, b) => (a.ts || 0) - (b.ts || 0));
}

function getMeta(sid) {
  const p = path.join(RUNS_DIR, sid, 'meta.json');
  try { return JSON.parse(fs.readFileSync(p, 'utf8')); } catch { return null; }
}

// ── Active session detection ──────────────────────────────────────────────────
function getActiveSessions() {
  const cutoff = Date.now() / 1000 - 30 * 60;
  const result = [];
  for (const sid of getSessions()) {
    const dir = path.join(RUNS_DIR, sid, 'channel');
    const all = [
      ...readJsonl(path.join(dir, 'inbox.jsonl')),
      ...readJsonl(path.join(dir, 'outbox.jsonl'))
    ].sort((a, b) => (a.ts || 0) - (b.ts || 0));
    if (!all.length) continue;
    const latest = all[all.length - 1];
    if (!latest || (latest.ts || 0) < cutoff) continue;
    if (latest.type === 'result') continue;
    const meta = getMeta(sid);
    const rawBody = typeof latest.body === 'string' ? latest.body : JSON.stringify(latest.body);
    result.push({
      sid,
      agent: meta ? (meta.agent || null) : null,
      lastType: latest.type || null,
      lastTs: latest.ts || null,
      lastBody: rawBody.slice(0, 60)
    });
  }
  return result;
}

// ── Worker grouping (by agent) ────────────────────────────────────────────────
function getWorkers(sid) {
  const msgs = getMessages(sid);
  const byAgent = {};
  for (const msg of msgs) {
    const agent = msg.from || (msg._dir === 'in' ? 'advisor' : 'worker');
    if (!byAgent[agent]) {
      byAgent[agent] = [];
    }
    byAgent[agent].push(msg);
  }
  const result = [];
  for (const agent in byAgent) {
    const agentMsgs = byAgent[agent];
    const latest = agentMsgs[agentMsgs.length - 1];
    const status = latest ? latest.type : null;
    let lastProgressBody = null;
    for (let i = agentMsgs.length - 1; i >= 0; i--) {
      if (agentMsgs[i].type === 'progress') {
        lastProgressBody = agentMsgs[i].body;
        break;
      }
    }
    let resultEnvelope = null;
    for (let i = agentMsgs.length - 1; i >= 0; i--) {
      if (agentMsgs[i].type === 'result' && typeof agentMsgs[i].body === 'object') {
        resultEnvelope = agentMsgs[i].body;
        break;
      }
    }
    result.push({
      agent,
      status,
      lastProgressBody: lastProgressBody ? (typeof lastProgressBody === 'string' ? lastProgressBody : JSON.stringify(lastProgressBody)) : null,
      resultEnvelope,
      messages: agentMsgs,
      lastTs: latest ? latest.ts : null
    });
  }
  return result;
}

// ── SSE client registry ───────────────────────────────────────────────────────
// Map<sid, Map<clientId, {res, afterSeq}>>
const sseClients = new Map();
let clientId = 0;

// Poll every 2 s for new messages and push to SSE clients
const lastKnown = new Map(); // sid -> max seq seen across all channels

setInterval(() => {
  for (const [sid, clients] of sseClients.entries()) {
    if (!clients.size) continue;
    const msgs = getMessages(sid);
    const prev = lastKnown.get(sid) || 0;
    const fresh = msgs.filter(m => (m.seq || 0) > prev);
    if (!fresh.length) continue;
    lastKnown.set(sid, Math.max(...msgs.map(m => m.seq || 0)));
    const payload = 'data: ' + JSON.stringify({ event: 'messages', msgs: fresh }) + '\n\n';
    for (const { res } of clients.values()) {
      try { res.write(payload); } catch (_) {}
    }
  }
}, 2000);

