function renderWorkerCards(workers,sid){var grid=document.getElementById('workersGrid');if(!grid)return;grid.innerHTML='';if(!workers.length){grid.innerHTML='<div class="empty"><div class="icon">&#128237;</div>No messages yet</div>';return;}workers.forEach(function(w){var card=buildWorkerCard(w,sid);grid.appendChild(card);})}
function buildWorkerCard(w,sid){var div=document.createElement('div');div.className='worker-card';div.dataset.agent=w.agent;var hdr=document.createElement('div');hdr.className='worker-card-header';hdr.innerHTML='<span class="worker-name">'+esc(w.agent||'unknown')+'</span><span class="badge '+typeClass(w.status)+'">'+esc(w.status||'?')+'</span><span class="worker-ts">'+esc(w.lastTs?fmt(w.lastTs):'')+'</span>';div.appendChild(hdr);var progressDiv=document.createElement('div');progressDiv.className='worker-progress-body';progressDiv.innerHTML=renderMd(w.lastProgressBody||'');div.appendChild(progressDiv);if(w.resultEnvelope){var re=w.resultEnvelope;var resultDiv=document.createElement('div');resultDiv.className='worker-result';var verdictColor=re.verdict==='complete'?'var(--c-result)':re.verdict==='partial'?'var(--c-progress)':'var(--c-terminate)';resultDiv.innerHTML='<div class="worker-result-verdict"><span class="badge" style="background:'+verdictColor+'">'+esc(re.verdict||'result')+'</span></div><div class="worker-result-summary">'+esc(re.summary||'')+'</div>'+(re.paths&&re.paths.length?'<div class="worker-result-paths">'+re.paths.map(function(p){return '<code>'+esc(p)+'</code>'}).join('')+'</div>':'');div.appendChild(resultDiv);if(re.sub_team_run_id){var stDiv=document.createElement('div');stDiv.className='worker-subteam';stDiv.innerHTML='<div class="subteam-title">Sub-team: '+esc(re.sub_team_run_id)+'</div><div class="subteam-cards" id="st-'+esc(re.sub_team_run_id)+'">Loading...</div>';div.appendChild(stDiv);fetch('/api/sessions/'+encodeURIComponent(sid)+'/sub-team-run/'+encodeURIComponent(re.sub_team_run_id)).then(function(r){return r.json();}).then(function(data){var container=document.getElementById('st-'+re.sub_team_run_id);if(!container)return;if(data.error){container.textContent=data.error;return;}var summaries=(data.state&&data.state.final_result&&data.state.final_result.summaries)||[];if(!summaries.length){container.textContent='No completed tasks yet.';return;}container.innerHTML='';summaries.forEach(function(s){var sc=document.createElement('div');sc.className='subteam-card';var result=s.output&&s.output.result?String(s.output.result):'';sc.innerHTML='<div class="subteam-card-header"><span class="subteam-role">'+esc(s.task_id)+'</span>'+(s.input&&s.input.description?'<span style="font-size:11px;color:var(--muted)">'+esc(s.input.description.slice(0,60))+'</span>':'')+'</div><div class="subteam-summary">'+esc(result.slice(0,300))+'</div>';container.appendChild(sc);});}).catch(function(){});}}}return div}
function loadSession(sid){currentSid=sid;document.getElementById('mainTitle').textContent=sid;document.querySelectorAll('.session-item').forEach(function(el){el.classList.toggle('active',el.dataset.sid===sid);});if(evtSrc){evtSrc.close();evtSrc=null;}var liveDot=document.getElementById('liveDot');liveDot.className='live-dot';document.getElementById('liveLabel').textContent='connecting…';loadWorkers(sid);setTimeout(function(){var maxSeq=0;fetch('/api/sessions/'+encodeURIComponent(sid)+'/workers').then(function(r){return r.json();}).then(function(workers){for(var i=0;i<workers.length;i++){for(var j=0;j<workers[i].messages.length;j++){var seq=workers[i].messages[j].seq||0;if(seq>maxSeq)maxSeq=seq;}}connectSse(sid,maxSeq);});},100);}
function connectSse(sid,afterSeq){var url='/events?sid='+encodeURIComponent(sid)+'&after='+afterSeq;evtSrc=new EventSource(url);evtSrc.onopen=function(){document.getElementById('liveDot').className='live-dot on';document.getElementById('liveLabel').textContent='live';};evtSrc.onmessage=function(e){try{var ev=JSON.parse(e.data);if(ev.event==='messages')loadWorkers(sid);}catch(_){}};evtSrc.onerror=function(){document.getElementById('liveDot').className='live-dot';document.getElementById('liveLabel').textContent='reconnecting…';};}
function loadSessions(){fetch('/api/sessions').then(function(r){return r.json();}).then(function(sessions){var list=document.getElementById('sessionList');if(!sessions.length){list.innerHTML='<div class="empty"><div class="icon">&#128193;</div>No sessions found</div>';return;}list.innerHTML='';for(var i=0;i<sessions.length;i++){var s=sessions[i];var el=document.createElement('div');el.className='session-item';el.dataset.sid=s.sid;el.innerHTML='<div class="session-sid">'+esc(s.sid)+'</div><div class="session-agent">'+esc(s.agent||'unknown')+'</div><div class="session-count">'+s.count+' message'+(s.count!==1?'s':'')+'</div>';el.onclick=(function(id){return function(){loadSession(id);}})(s.sid);list.appendChild(el);}})}
var TYPE_COLORS={"task":"var(--c-task)","progress":"var(--c-progress)","result":"var(--c-result)","guidance":"var(--c-guidance)","terminate":"var(--c-terminate)","question":"var(--c-question)"};
function fmtRel(ts){if(!ts)return"";var s=Math.floor(Date.now()/1000-ts);if(s<60)return s+"s ago";if(s<3600)return Math.floor(s/60)+"m ago";return Math.floor(s/3600)+"h ago";}
function loadActive(){fetch('/api/active').then(function(r){return r.json();}).then(function(workers){var list=document.getElementById('activeList');if(!list)return;if(!workers.length){list.innerHTML='<span class="active-empty">No active workers.</span>';return;}list.innerHTML='';for(var i=0;i<workers.length;i++){var w=workers[i];var el=document.createElement('a');el.className='active-row';el.href='/session/'+encodeURIComponent(w.sid);var shortSid=w.sid.length>20?w.sid.slice(0,10)+'…'+w.sid.slice(-6):w.sid;var tc=TYPE_COLORS[w.lastType]||'var(--c-default)';el.innerHTML='<span class="active-row-sid">'+esc(shortSid)+'</span><span class="active-row-agent">'+esc(w.agent||'unknown')+'</span><span class="active-row-badge" style="background:'+tc+'">'+esc(w.lastType||'?')+'</span><span class="active-row-ts">'+esc(fmtRel(w.lastTs))+'</span>'+(w.lastBody?'<span class="active-row-body">— '+esc(w.lastBody)+'</span>':'');list.appendChild(el);}}).catch(function(){});}
loadActive();setInterval(loadActive,5000);loadSessions();
</script>
</body>
</html>`;
}

// ── Per-session live page ─────────────────────────────────────────────────────
function htmlSessionPage(sid, meta) {
  const safeSid = sid.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
  const agent = (meta && meta.agent) ? String(meta.agent) : 'unknown';
  const safeAgent = agent.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
  const jsSid = JSON.stringify(sid);
  return `<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Session ${safeSid}</title>
<style>
:root{--bg:#0f1117;--surface:#1a1d27;--border:#2a2d3e;--text:#e2e4f0;--muted:#6b7094;--accent:#7c6af7;--c-task:#3b82f6;--c-progress:#f59e0b;--c-result:#22c55e;--c-guidance:#f97316;--c-terminate:#ef4444;--c-question:#a855f7;--c-default:#6b7094}
*{box-sizing:border-box;margin:0;padding:0}
