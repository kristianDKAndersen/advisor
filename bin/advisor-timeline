<script>
var THIRTY_MIN=30*60*1000;
function esc(s){return String(s).replace(/&/g,"&amp;").replace(/</g,"&lt;").replace(/>/g,"&gt;").replace(/"/g,"&quot;")}
function fmt(ts){var d=new Date(ts*1000);return d.toLocaleTimeString("en-GB",{hour12:false,hour:"2-digit",minute:"2-digit",second:"2-digit"})}
function bodyText(b){if(typeof b==="object"&&b){var p=[];if(b.summary)p.push(b.summary);if(b.verdict)p.push("verdict: "+b.verdict);if(b.paths&&b.paths.length)p.push("paths:\\n  "+b.paths.join("\\n  "));return p.join("\\n")}return String(b||"")}
function typeClass(t){return["task","progress","result","guidance","terminate","question"].indexOf(t)>=0?"t-"+t:"t-default"}
function makeEntry(msg){
  var div=document.createElement("div");
  div.className="entry "+typeClass(msg.type);
  var body=bodyText(msg.body);
  var isLong=body.length>200;
  var from=msg.from||(msg._dir==="in"?"advisor":"worker");
  var bc="badge"+(msg.type==="progress"?" badge-progress":msg.type==="result"?" badge-result":"");
  div.innerHTML="<div class=\\"entry-dot\\"></div><div class=\\"card\\"><div class=\\"card-head\\"><span class=\\""+bc+"\\">"+esc(msg.type)+"</span><span class=\\"from\\">"+esc(from)+"</span><span class=\\"seq\\">#"+esc(msg.seq)+" "+esc(fmt(msg.ts))+"</span></div><div class=\\"body-text"+(isLong?" long":"")+"\\">"+esc(body)+"</div></div>";
  div.querySelector(".body-text").onclick=function(){this.classList.toggle("open");this.classList.remove("long");};
  return div;
}

// cols: Map sid -> {el, evtSrc, lastActivityMs, completed}
var cols={};
var closedSids=new Set();

function safeId(sid){return sid.replace(/[^a-zA-Z0-9-_]/g,"_")}

function closeCol(sid){
  closedSids.add(sid);
  if(cols[sid]){
    if(cols[sid].evtSrc){try{cols[sid].evtSrc.close();}catch(_){}}
    if(cols[sid].el)cols[sid].el.remove();
    delete cols[sid];
  }
  var grid=document.getElementById("cols");
  if(grid&&!Object.keys(cols).length)grid.innerHTML="<div class=\\"empty-state\\">No active workers.</div>";
}

function markComplete(sid){
  if(!cols[sid])return;
  cols[sid].completed=true;
  var badge=document.getElementById("colbadge-"+safeId(sid));
  if(badge)badge.classList.add("show");
}

function addCol(w){
  var grid=document.getElementById("cols");
  var empty=grid.querySelector(".empty-state");
  if(empty)empty.remove();
  var sid=w.sid;
  var iid=safeId(sid);
  var shortSid=sid.length>22?sid.slice(0,10)+"\\u2026"+sid.slice(-8):sid;
  var el=document.createElement("div");
  el.className="col";
  el.dataset.sid=sid;
  el.innerHTML=
    "<div class=\\"col-hdr\\">"+
      "<div class=\\"col-meta\\">"+
        "<a class=\\"col-sid\\" href=\\"/session/"+encodeURIComponent(sid)+"\\" target=\\"_blank\\">"+esc(shortSid)+"</a>"+
        "<div class=\\"col-row2\\">"+
          "<span class=\\"col-agent\\">"+esc(w.agent||"unknown")+"</span>"+
          "<span class=\\"col-ts\\" id=\\"colts-"+esc(iid)+"\\">"+(w.lastTs?esc(fmt(w.lastTs)):"")+"</span>"+
          "<span class=\\"col-badge\\" id=\\"colbadge-"+esc(iid)+"\\">complete</span>"+
        "</div>"+
      "</div>"+
      "<button class=\\"col-close\\" onclick=\\"closeCol("+JSON.stringify(sid)+")\\">&times;</button>"+
    "</div>"+
    "<div class=\\"col-body\\"><div class=\\"tl-line\\"></div><div id=\\"colentries-"+esc(iid)+"\\"></div></div>";
  grid.appendChild(el);
  cols[sid]={el:el, evtSrc:null, lastActivityMs:Date.now(), completed:false};
  fetch("/api/sessions/"+encodeURIComponent(sid)+"/messages")
    .then(function(r){return r.json();})
    .then(function(msgs){
      var list=document.getElementById("colentries-"+iid);
      if(!list)return;
      for(var i=0;i<msgs.length;i++){
        list.appendChild(makeEntry(msgs[i]));
        if(msgs[i].type==="result")markComplete(sid);
      }
      var body=el.querySelector(".col-body");
      if(body)body.scrollTop=body.scrollHeight;
      var maxSeq=msgs.length?Math.max.apply(null,msgs.map(function(m){return m.seq||0;})):0;
      connectColSse(sid,maxSeq);
    }).catch(function(){});
}

function connectColSse(sid,afterSeq){
  if(!cols[sid])return;
  var iid=safeId(sid);
  var es=new EventSource("/events?sid="+encodeURIComponent(sid)+"&after="+afterSeq);
  cols[sid].evtSrc=es;
  es.onmessage=function(e){
    if(!cols[sid])return;
    try{
      var ev=JSON.parse(e.data);
      if(ev.event!=="messages")return;
      var list=document.getElementById("colentries-"+iid);
      if(!list)return;
      cols[sid].lastActivityMs=Date.now();
      for(var i=0;i<ev.msgs.length;i++){
        list.appendChild(makeEntry(ev.msgs[i]));
        if(ev.msgs[i].type==="result")markComplete(sid);
        var tsEl=document.getElementById("colts-"+iid);
        if(tsEl&&ev.msgs[i].ts)tsEl.textContent=fmt(ev.msgs[i].ts);
      }
      var body=cols[sid].el.querySelector(".col-body");
      if(body)body.scrollTop=body.scrollHeight;
    }catch(_){}
  };
}

function refreshActive(){
  fetch("/api/active")
    .then(function(r){return r.json();})
    .then(function(workers){
      var activeSids=new Set(workers.map(function(w){return w.sid;}));
      for(var i=0;i<workers.length;i++){
        var w=workers[i];
        if(!cols[w.sid]&&!closedSids.has(w.sid))addCol(w);
      }
      var now=Date.now();
      for(var sid in cols){
        if(now-cols[sid].lastActivityMs>THIRTY_MIN){
          closeCol(sid);
        }
      }
      document.getElementById("pollLabel").textContent="live";
    }).catch(function(){
      document.getElementById("pollLabel").textContent="error";
    });
}
refreshActive();
setInterval(refreshActive,5000);
</script>
</body>
</html>`;
}

// ── Static file helper ────────────────────────────────────────────────────────
const MIME = {
  '.js': 'application/javascript',
  '.mjs': 'application/javascript',
  '.css': 'text/css',
  '.svg': 'image/svg+xml',
  '.html': 'text/html; charset=utf-8',
  '.json': 'application/json',
  '.png': 'image/png',
  '.ico': 'image/x-icon',
  '.woff2': 'font/woff2',
  '.woff': 'font/woff',
  '.ttf': 'font/ttf',
};

function serveStaticFile(res, filePath) {
  try {
    const data = fs.readFileSync(filePath);
    const ct = MIME[path.extname(filePath)] || 'application/octet-stream';
    res.writeHead(200, { 'Content-Type': ct, 'Cache-Control': 'public, max-age=3600' });
    res.end(data);
  } catch (_) {
    res.writeHead(404, { 'Content-Type': 'text/plain' });
    res.end('Not found');
  }
}

// ── HTTP server ───────────────────────────────────────────────────────────────
function jsonRes(res, data, status) {
  res.writeHead(status || 200, { 'Content-Type': 'application/json', 'Cache-Control': 'no-cache' });
  res.end(JSON.stringify(data));
}

function parseQueryString(url) {
  const idx = url.indexOf('?');
  if (idx < 0) return {};
  const params = {};
  for (const part of url.slice(idx + 1).split('&')) {
    const [k, v] = part.split('=');
    if (k) params[decodeURIComponent(k)] = v ? decodeURIComponent(v) : '';
  }
  return params;
}

const server = http.createServer((req, res) => {
  const urlPath = req.url.split('?')[0].replace(/\/+$/, '') || '/';

  // Root — Svelte shell when built, legacy timeline otherwise
  if (req.method === 'GET' && urlPath === '/') {
    if (CLIENT_DIST_EXISTS) {
      serveStaticFile(res, path.join(CLIENT_DIST, 'index.html'));
    } else {
      res.writeHead(200, { 'Content-Type': 'text/html; charset=utf-8', 'Cache-Control': 'no-cache' });
      res.end(htmlPage());
    }
    return;
  }

  // Assets from client/dist/assets/
  if (req.method === 'GET' && urlPath.startsWith('/assets/')) {
    const rel = urlPath.slice('/assets/'.length);
    if (rel.includes('..') || path.isAbsolute(rel)) {
      res.writeHead(400, { 'Content-Type': 'text/plain' });
      res.end('Bad request');
      return;
    }
    serveStaticFile(res, path.join(CLIENT_DIST, 'assets', rel));
    return;
  }

  // Legacy timeline (old / UI, always accessible)
  if (req.method === 'GET' && urlPath === '/legacy') {
    res.writeHead(200, { 'Content-Type': 'text/html; charset=utf-8', 'Cache-Control': 'no-cache' });
    res.end(htmlPage());
    return;
  }

  // Health check
  if (req.method === 'GET' && urlPath === '/health') {
    jsonRes(res, { ok: true, port });
    return;
  }

  // Live multi-column page
  if (req.method === 'GET' && urlPath === '/live') {
    res.writeHead(200, { 'Content-Type': 'text/html; charset=utf-8', 'Cache-Control': 'no-cache' });
    res.end(htmlLivePage());
    return;
  }

  // Per-session live page
  const sessionPageMatch = urlPath.match(/^\/session\/([^/]+)$/);
  if (req.method === 'GET' && sessionPageMatch) {
    const sid = decodeURIComponent(sessionPageMatch[1]);
    const meta = getMeta(sid);
    res.writeHead(200, { 'Content-Type': 'text/html; charset=utf-8', 'Cache-Control': 'no-cache' });
    res.end(htmlSessionPage(sid, meta));
    return;
  }

  // Sessions list
  if (req.method === 'GET' && urlPath === '/api/sessions') {
    const sids = getSessions();
    const result = sids.map(sid => {
      const meta = getMeta(sid);
      const msgs = getMessages(sid);
      return {
        sid,
        agent: meta ? (meta.agent || null) : null,
        goal:  meta ? (meta.goal  || null) : null,
        count: msgs.length
      };
    });
    jsonRes(res, result);
    return;
  }

  // Session messages
  const msgMatch = urlPath.match(/^\/api\/sessions\/([^/]+)\/messages$/);
  if (req.method === 'GET' && msgMatch) {
    const sid = decodeURIComponent(msgMatch[1]);
    jsonRes(res, getMessages(sid));
    return;
  }

  // Session detail (meta + session.json + synthesis.log)
  const detailMatch = urlPath.match(/^\/api\/sessions\/([^/]+)\/detail$/);
  if (req.method === 'GET' && detailMatch) {
    const sid = decodeURIComponent(detailMatch[1]);
    const sidDir = path.join(RUNS_DIR, sid);
    if (!fs.existsSync(sidDir)) {
      jsonRes(res, { error: 'not found' }, 404);
      return;
    }
    let session = null;
    try { session = JSON.parse(fs.readFileSync(path.join(sidDir, 'session.json'), 'utf8')); } catch (_) {}
    const synthesisRecords = readJsonl(path.join(sidDir, 'synthesis.log'));
    jsonRes(res, { meta: getMeta(sid), session, synthesisRecords });
    return;
  }

  // Active sessions
  if (req.method === 'GET' && urlPath === '/api/active') {
    jsonRes(res, getActiveSessions());
    return;
  }

  // Workers grouped by agent
  const workersMatch = urlPath.match(/^\/api\/sessions\/([^/]+)\/workers$/);
  if (req.method === 'GET' && workersMatch) {
    const sid = decodeURIComponent(workersMatch[1]);
    jsonRes(res, getWorkers(sid));
    return;
  }

  // Sub-team run state and tasks
  const subteamMatch = urlPath.match(/^\/api\/sessions\/([^/]+)\/sub-team-run\/([^/]+)$/);
  if (req.method === 'GET' && subteamMatch) {
    const sid = decodeURIComponent(subteamMatch[1]);
    const runId = decodeURIComponent(subteamMatch[2]);
    const stateFile = path.join(RUNS_DIR, sid, 'output', 'sub-team-runs', runId, 'state.json');
    const taskFile = path.join(RUNS_DIR, sid, 'output', 'sub-team-runs', runId, 'task-list.json');
    let state = null;
    let tasks = null;
    try { state = JSON.parse(fs.readFileSync(stateFile, 'utf8')); } catch (_) {}
    try { tasks = JSON.parse(fs.readFileSync(taskFile, 'utf8')); } catch (_) {}
    if (!state && !tasks) {
      jsonRes(res, { error: 'not found' }, 404);
      return;
    }
    jsonRes(res, { state, tasks });
    return;
  }

  // SSE endpoint
  if (req.method === 'GET' && urlPath === '/events') {
    const qs = parseQueryString(req.url);
    const sid = qs.sid;
    const after = parseInt(qs.after || '0', 10);
    if (!sid) { jsonRes(res, { error: 'sid required' }, 400); return; }

    res.writeHead(200, {
      'Content-Type': 'text/event-stream',
      'Cache-Control': 'no-cache',
      'Connection': 'keep-alive',
      'X-Accel-Buffering': 'no'
    });
    res.write(': connected\n\n');

    // Prime lastKnown so polling knows the baseline
    const msgs = getMessages(sid);
    const maxSeq = msgs.length ? Math.max(...msgs.map(m => m.seq || 0)) : 0;
    if (!lastKnown.has(sid) || lastKnown.get(sid) < maxSeq) {
      lastKnown.set(sid, maxSeq);
    }

    // Register client
    if (!sseClients.has(sid)) sseClients.set(sid, new Map());
    const id = ++clientId;
    sseClients.get(sid).set(id, { res });

    // Heartbeat to keep connection alive
    const hb = setInterval(() => {
      try { res.write(': ping\n\n'); } catch (_) { clearInterval(hb); }
    }, 15000);

    req.on('close', () => {
      clearInterval(hb);
      const clients = sseClients.get(sid);
      if (clients) { clients.delete(id); if (!clients.size) sseClients.delete(sid); }
    });
    return;
  }

  res.writeHead(404, { 'Content-Type': 'text/plain' });
  res.end('Not found');
});

server.listen(port, '127.0.0.1', () => {
  process.stdout.write('advisor-timeline listening on http://127.0.0.1:' + port + '\n');
  process.stdout.write('Reads sessions from: ' + RUNS_DIR + '\n');
});

server.on('error', err => {
  process.stderr.write('Server error: ' + err.message + '\n');
  process.exit(1);
});
