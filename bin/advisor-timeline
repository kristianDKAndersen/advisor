#!/usr/bin/env node
'use strict';

// advisor-timeline — zero-dependency Node.js HTTP server
// Serves a color-coded SSE timeline of ~/.advisor/runs/<sid>/channel messages.
// Usage: node bin/advisor-timeline [--port <n>]  (default: 7878)

const http = require('http');
const fs = require('fs');
const path = require('path');
const os = require('os');

// ── Config ────────────────────────────────────────────────────────────────────
const RUNS_DIR = path.join(os.homedir(), '.advisor', 'runs');

const argv = process.argv.slice(2);
let port = 7878;
for (let i = 0; i < argv.length; i++) {
  if (argv[i] === '--port' && argv[i + 1]) { port = parseInt(argv[i + 1], 10); i++; }
}

// ── JSONL helpers ─────────────────────────────────────────────────────────────
function readJsonl(filePath) {
  if (!fs.existsSync(filePath)) return [];
  const out = [];
  for (const line of fs.readFileSync(filePath, 'utf8').split('\n')) {
    if (!line.trim()) continue;
    try { out.push(JSON.parse(line)); } catch (_) {}
  }
  return out;
}

// ── Session helpers ───────────────────────────────────────────────────────────
function getSessions() {
  if (!fs.existsSync(RUNS_DIR)) return [];
  return fs.readdirSync(RUNS_DIR)
    .filter(name => {
      const p = path.join(RUNS_DIR, name);
      try { return fs.statSync(p).isDirectory(); } catch { return false; }
    })
    .sort()
    .reverse();
}

function getMessages(sid) {
  const dir = path.join(RUNS_DIR, sid, 'channel');
  const inbox  = readJsonl(path.join(dir, 'inbox.jsonl')).map(m => ({ ...m, _dir: 'in' }));
  const outbox = readJsonl(path.join(dir, 'outbox.jsonl')).map(m => ({ ...m, _dir: 'out' }));
  return [...inbox, ...outbox].sort((a, b) => (a.ts || 0) - (b.ts || 0));
}

function getMeta(sid) {
  const p = path.join(RUNS_DIR, sid, 'meta.json');
  try { return JSON.parse(fs.readFileSync(p, 'utf8')); } catch { return null; }
}

// ── SSE client registry ───────────────────────────────────────────────────────
// Map<sid, Map<clientId, {res, afterSeq}>>
const sseClients = new Map();
let clientId = 0;

// Poll every 2 s for new messages and push to SSE clients
const lastKnown = new Map(); // sid -> max seq seen across all channels

setInterval(() => {
  for (const [sid, clients] of sseClients.entries()) {
    if (!clients.size) continue;
    const msgs = getMessages(sid);
    const prev = lastKnown.get(sid) || 0;
    const fresh = msgs.filter(m => (m.seq || 0) > prev);
    if (!fresh.length) continue;
    lastKnown.set(sid, Math.max(...msgs.map(m => m.seq || 0)));
    const payload = 'data: ' + JSON.stringify({ event: 'messages', msgs: fresh }) + '\n\n';
    for (const { res } of clients.values()) {
      try { res.write(payload); } catch (_) {}
    }
  }
}, 2000);

// ── HTML page ─────────────────────────────────────────────────────────────────
function htmlPage() {
  return '<!DOCTYPE html>\n' +
'<html lang="en">\n' +
'<head>\n' +
'<meta charset="utf-8">\n' +
'<meta name="viewport" content="width=device-width, initial-scale=1">\n' +
'<title>Advisor Timeline</title>\n' +
'<style>\n' +
':root {\n' +
'  --bg:#0f1117; --surface:#1a1d27; --border:#2a2d3e; --text:#e2e4f0;\n' +
'  --muted:#6b7094; --accent:#7c6af7;\n' +
'  --c-task:#3b82f6; --c-progress:#f59e0b; --c-result:#22c55e;\n' +
'  --c-guidance:#f97316; --c-terminate:#ef4444; --c-question:#a855f7; --c-default:#6b7094;\n' +
'}\n' +
'* { box-sizing:border-box; margin:0; padding:0; }\n' +
'body { background:var(--bg); color:var(--text); font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",system-ui,sans-serif; font-size:14px; display:flex; height:100vh; overflow:hidden; }\n' +
'.sidebar { width:260px; min-width:260px; background:var(--surface); border-right:1px solid var(--border); display:flex; flex-direction:column; overflow:hidden; }\n' +
'.sidebar-header { padding:14px 16px; border-bottom:1px solid var(--border); font-weight:700; letter-spacing:-.03em; font-size:15px; }\n' +
'.sidebar-header em { color:var(--accent); font-style:normal; }\n' +
'.session-list { flex:1; overflow-y:auto; padding:8px; }\n' +
'.session-item { padding:10px 12px; border-radius:8px; cursor:pointer; margin-bottom:4px; border:1px solid transparent; transition:background .15s; }\n' +
'.session-item:hover { background:rgba(124,106,247,.1); border-color:rgba(124,106,247,.3); }\n' +
'.session-item.active { background:rgba(124,106,247,.18); border-color:rgba(124,106,247,.55); }\n' +
'.session-sid { font-family:monospace; font-size:11px; color:var(--muted); margin-bottom:3px; }\n' +
'.session-agent { font-size:13px; font-weight:500; }\n' +
'.session-count { font-size:11px; color:var(--muted); margin-top:2px; }\n' +
'.main { flex:1; display:flex; flex-direction:column; overflow:hidden; }\n' +
'.main-header { padding:14px 18px; border-bottom:1px solid var(--border); background:var(--surface); display:flex; align-items:center; gap:12px; }\n' +
'.main-header h2 { font-size:14px; font-weight:600; letter-spacing:-.02em; flex:1; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; }\n' +
'.live { display:flex; align-items:center; gap:6px; font-size:12px; color:var(--muted); }\n' +
'.live-dot { width:8px; height:8px; border-radius:50%; background:var(--muted); }\n' +
'.live-dot.on { background:var(--c-result); animation:blink 2s infinite; }\n' +
'@keyframes blink { 0%,100%{opacity:1} 50%{opacity:.35} }\n' +
'.wrap { flex:1; overflow-y:auto; padding:20px; }\n' +
'.timeline { max-width:860px; margin:0 auto; position:relative; padding-left:110px; }\n' +
'.tl-line { position:absolute; left:100px; top:0; bottom:0; width:2px; background:var(--border); border-radius:1px; }\n' +
'.entry { display:flex; gap:0; margin-bottom:14px; position:relative; }\n' +
'.entry-time { position:absolute; left:-110px; width:94px; text-align:right; font-family:monospace; font-size:11px; color:var(--muted); padding-top:13px; }\n' +
'.entry-dot { position:absolute; left:-6px; top:12px; width:12px; height:12px; border-radius:50%; border:2px solid var(--bg); flex-shrink:0; z-index:1; }\n' +
'.card { flex:1; background:var(--surface); border:1px solid var(--border); border-radius:10px; padding:11px 14px; min-width:0; }\n' +
'.card-head { display:flex; align-items:center; gap:8px; margin-bottom:7px; }\n' +
'.badge { font-size:10px; font-weight:700; text-transform:uppercase; letter-spacing:.06em; padding:2px 7px; border-radius:4px; color:#fff; }\n' +
'.badge-progress { color:#000; }\n' +
'.badge-result { color:#000; }\n' +
'.from { font-family:monospace; font-size:12px; color:var(--muted); }\n' +
'.seq { margin-left:auto; font-family:monospace; font-size:11px; color:var(--muted); }\n' +
'.body-text { font-size:13px; line-height:1.55; white-space:pre-wrap; word-break:break-word; max-height:180px; overflow:hidden; cursor:pointer; position:relative; }\n' +
'.body-text.long::after { content:""; position:absolute; bottom:0; left:0; right:0; height:36px; background:linear-gradient(transparent,var(--surface)); }\n' +
'.body-text.open { max-height:none; }\n' +
'.body-text.open::after { display:none; }\n' +
'.empty { text-align:center; color:var(--muted); padding:60px 20px; }\n' +
'.empty .icon { font-size:30px; margin-bottom:10px; }\n' +
/* type → dot and badge background colors */
'.t-task .entry-dot,.t-task .badge{background:var(--c-task)}\n' +
'.t-progress .entry-dot,.t-progress .badge{background:var(--c-progress)}\n' +
'.t-result .entry-dot,.t-result .badge{background:var(--c-result)}\n' +
'.t-guidance .entry-dot,.t-guidance .badge{background:var(--c-guidance)}\n' +
'.t-terminate .entry-dot,.t-terminate .badge{background:var(--c-terminate)}\n' +
'.t-question .entry-dot,.t-question .badge{background:var(--c-question)}\n' +
'.t-default .entry-dot,.t-default .badge{background:var(--c-default)}\n' +
'::-webkit-scrollbar{width:5px} ::-webkit-scrollbar-track{background:transparent} ::-webkit-scrollbar-thumb{background:var(--border);border-radius:3px}\n' +
'</style>\n' +
'</head>\n' +
'<body>\n' +
'<div class="sidebar">\n' +
'  <div class="sidebar-header">Advisor <em>Timeline</em></div>\n' +
'  <div class="session-list" id="sessionList"><div class="empty"><div class="icon">&#8987;</div>Loading…</div></div>\n' +
'</div>\n' +
'<div class="main">\n' +
'  <div class="main-header">\n' +
'    <h2 id="mainTitle">Select a session</h2>\n' +
'    <div class="live"><div class="live-dot" id="liveDot"></div><span id="liveLabel">SSE</span></div>\n' +
'  </div>\n' +
'  <div class="wrap">\n' +
'    <div class="timeline" id="timeline"><div class="empty"><div class="icon">&#128225;</div>Pick a session on the left</div></div>\n' +
'  </div>\n' +
'</div>\n' +
'<script>\n' +
'function esc(s){return String(s).replace(/&/g,"&amp;").replace(/</g,"&lt;").replace(/>/g,"&gt;").replace(/"/g,"&quot;")}\n' +
'function fmt(ts){var d=new Date(ts*1000);return d.toLocaleTimeString("en-GB",{hour12:false,hour:"2-digit",minute:"2-digit",second:"2-digit"})}\n' +
'function bodyText(b){if(typeof b==="object"&&b){var p=[];if(b.summary)p.push(b.summary);if(b.verdict)p.push("verdict: "+b.verdict);if(b.paths&&b.paths.length)p.push("paths:\\n  "+b.paths.join("\\n  "));return p.join("\\n")}return String(b||"")}\n' +
'function typeClass(t){var ok=["task","progress","result","guidance","terminate","question"];return ok.indexOf(t)>=0?"t-"+t:"t-default"}\n' +
'\n' +
'function makeEntry(msg){\n' +
'  var div=document.createElement("div");\n' +
'  var tc=typeClass(msg.type);\n' +
'  div.className="entry "+tc;\n' +
'  var body=bodyText(msg.body);\n' +
'  var isLong=body.length>260;\n' +
'  var from=msg.from||(msg._dir==="in"?"advisor":"worker");\n' +
'  var badgeClass="badge"+(msg.type==="progress"?" badge-progress":msg.type==="result"?" badge-result":"");\n' +
'  div.innerHTML=\n' +
'    "<div class=\\"entry-time\\">"+esc(fmt(msg.ts))+"</div>"\n' +
'    +"<div class=\\"entry-dot\\"></div>"\n' +
'    +"<div class=\\"card\\">"\n' +
'      +"<div class=\\"card-head\\">"\n' +
'        +"<span class=\\""+badgeClass+"\\">"+esc(msg.type)+"</span>"\n' +
'        +"<span class=\\"from\\">"+esc(from)+"</span>"\n' +
'        +"<span class=\\"seq\\">#"+esc(msg.seq)+"</span>"\n' +
'      +"</div>"\n' +
'      +"<div class=\\"body-text"+(isLong?" long":"")+"\\">"+esc(body)+"</div>"\n' +
'    +"</div>";\n' +
'  var bodyEl=div.querySelector(".body-text");\n' +
'  bodyEl.onclick=function(){this.classList.toggle("open");this.classList.remove("long");};\n' +
'  return div;\n' +
'}\n' +
'\n' +
'var currentSid=null;\n' +
'var evtSrc=null;\n' +
'\n' +
'function renderTimeline(msgs){\n' +
'  var tl=document.getElementById("timeline");\n' +
'  tl.innerHTML="";\n' +
'  if(!msgs.length){tl.innerHTML="<div class=\\"empty\\"><div class=\\"icon\\">&#128237;</div>No messages yet</div>";return;}\n' +
'  var line=document.createElement("div");line.className="tl-line";tl.appendChild(line);\n' +
'  for(var i=0;i<msgs.length;i++)tl.appendChild(makeEntry(msgs[i]));\n' +
'}\n' +
'\n' +
'function appendEntries(msgs){\n' +
'  var tl=document.getElementById("timeline");\n' +
'  if(tl.querySelector(".empty")){tl.innerHTML="";var line=document.createElement("div");line.className="tl-line";tl.appendChild(line);}\n' +
'  for(var i=0;i<msgs.length;i++)tl.appendChild(makeEntry(msgs[i]));\n' +
'  tl.parentElement.scrollTop=tl.parentElement.scrollHeight;\n' +
'}\n' +
'\n' +
'function loadSession(sid){\n' +
'  currentSid=sid;\n' +
'  document.getElementById("mainTitle").textContent=sid;\n' +
'  document.querySelectorAll(".session-item").forEach(function(el){el.classList.toggle("active",el.dataset.sid===sid);});\n' +
'  if(evtSrc){evtSrc.close();evtSrc=null;}\n' +
'  var liveDot=document.getElementById("liveDot");\n' +
'  liveDot.className="live-dot";\n' +
'  document.getElementById("liveLabel").textContent="connecting…";\n' +
'  fetch("/api/sessions/"+encodeURIComponent(sid)+"/messages")\n' +
'    .then(function(r){return r.json();})\n' +
'    .then(function(msgs){\n' +
'      renderTimeline(msgs);\n' +
'      var maxSeq=msgs.length?Math.max.apply(null,msgs.map(function(m){return m.seq||0;})):0;\n' +
'      connectSse(sid,maxSeq);\n' +
'    });\n' +
'}\n' +
'\n' +
'function connectSse(sid,afterSeq){\n' +
'  var url="/events?sid="+encodeURIComponent(sid)+"&after="+afterSeq;\n' +
'  evtSrc=new EventSource(url);\n' +
'  evtSrc.onopen=function(){\n' +
'    document.getElementById("liveDot").className="live-dot on";\n' +
'    document.getElementById("liveLabel").textContent="live";\n' +
'  };\n' +
'  evtSrc.onmessage=function(e){\n' +
'    try{\n' +
'      var ev=JSON.parse(e.data);\n' +
'      if(ev.event==="messages")appendEntries(ev.msgs);\n' +
'    }catch(_){}\n' +
'  };\n' +
'  evtSrc.onerror=function(){\n' +
'    document.getElementById("liveDot").className="live-dot";\n' +
'    document.getElementById("liveLabel").textContent="reconnecting…";\n' +
'  };\n' +
'}\n' +
'\n' +
'function loadSessions(){\n' +
'  fetch("/api/sessions")\n' +
'    .then(function(r){return r.json();})\n' +
'    .then(function(sessions){\n' +
'      var list=document.getElementById("sessionList");\n' +
'      if(!sessions.length){list.innerHTML="<div class=\\"empty\\"><div class=\\"icon\\">&#128193;</div>No sessions found</div>";return;}\n' +
'      list.innerHTML="";\n' +
'      for(var i=0;i<sessions.length;i++){\n' +
'        var s=sessions[i];\n' +
'        var el=document.createElement("div");\n' +
'        el.className="session-item";\n' +
'        el.dataset.sid=s.sid;\n' +
'        el.innerHTML="<div class=\\"session-sid\\">"+esc(s.sid)+"</div>"\n' +
'          +"<div class=\\"session-agent\\">"+esc(s.agent||"unknown")+"</div>"\n' +
'          +"<div class=\\"session-count\\">"+s.count+" message"+(s.count!==1?"s":"")+"</div>";\n' +
'        el.onclick=(function(id){return function(){loadSession(id);};})(s.sid);\n' +
'        list.appendChild(el);\n' +
'      }\n' +
'    });\n' +
'}\n' +
'\n' +
'loadSessions();\n' +
'</script>\n' +
'</body>\n' +
'</html>\n';
}

// ── HTTP server ───────────────────────────────────────────────────────────────
function jsonRes(res, data, status) {
  res.writeHead(status || 200, { 'Content-Type': 'application/json', 'Cache-Control': 'no-cache' });
  res.end(JSON.stringify(data));
}

function parseQueryString(url) {
  const idx = url.indexOf('?');
  if (idx < 0) return {};
  const params = {};
  for (const part of url.slice(idx + 1).split('&')) {
    const [k, v] = part.split('=');
    if (k) params[decodeURIComponent(k)] = v ? decodeURIComponent(v) : '';
  }
  return params;
}

const server = http.createServer((req, res) => {
  const urlPath = req.url.split('?')[0].replace(/\/+$/, '') || '/';

  // Static HTML
  if (req.method === 'GET' && urlPath === '/') {
    res.writeHead(200, { 'Content-Type': 'text/html; charset=utf-8', 'Cache-Control': 'no-cache' });
    res.end(htmlPage());
    return;
  }

  // Sessions list
  if (req.method === 'GET' && urlPath === '/api/sessions') {
    const sids = getSessions();
    const result = sids.map(sid => {
      const meta = getMeta(sid);
      const msgs = getMessages(sid);
      return {
        sid,
        agent: meta ? (meta.agent || null) : null,
        goal:  meta ? (meta.goal  || null) : null,
        count: msgs.length
      };
    });
    jsonRes(res, result);
    return;
  }

  // Session messages
  const msgMatch = urlPath.match(/^\/api\/sessions\/([^/]+)\/messages$/);
  if (req.method === 'GET' && msgMatch) {
    const sid = decodeURIComponent(msgMatch[1]);
    jsonRes(res, getMessages(sid));
    return;
  }

  // SSE endpoint
  if (req.method === 'GET' && urlPath === '/events') {
    const qs = parseQueryString(req.url);
    const sid = qs.sid;
    const after = parseInt(qs.after || '0', 10);
    if (!sid) { jsonRes(res, { error: 'sid required' }, 400); return; }

    res.writeHead(200, {
      'Content-Type': 'text/event-stream',
      'Cache-Control': 'no-cache',
      'Connection': 'keep-alive',
      'X-Accel-Buffering': 'no'
    });
    res.write(': connected\n\n');

    // Prime lastKnown so polling knows the baseline
    const msgs = getMessages(sid);
    const maxSeq = msgs.length ? Math.max(...msgs.map(m => m.seq || 0)) : 0;
    if (!lastKnown.has(sid) || lastKnown.get(sid) < maxSeq) {
      lastKnown.set(sid, maxSeq);
    }

    // Register client
    if (!sseClients.has(sid)) sseClients.set(sid, new Map());
    const id = ++clientId;
    sseClients.get(sid).set(id, { res });

    // Heartbeat to keep connection alive
    const hb = setInterval(() => {
      try { res.write(': ping\n\n'); } catch (_) { clearInterval(hb); }
    }, 15000);

    req.on('close', () => {
      clearInterval(hb);
      const clients = sseClients.get(sid);
      if (clients) { clients.delete(id); if (!clients.size) sseClients.delete(sid); }
    });
    return;
  }

  res.writeHead(404, { 'Content-Type': 'text/plain' });
  res.end('Not found');
});

server.listen(port, '127.0.0.1', () => {
  process.stdout.write('advisor-timeline listening on http://127.0.0.1:' + port + '\n');
  process.stdout.write('Reads sessions from: ' + RUNS_DIR + '\n');
});

server.on('error', err => {
  process.stderr.write('Server error: ' + err.message + '\n');
  process.exit(1);
});
