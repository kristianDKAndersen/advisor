<script>
var SID=${jsSid};
var evtSrc=null;
function esc(s){return String(s).replace(/&/g,"&amp;").replace(/</g,"&lt;").replace(/>/g,"&gt;").replace(/"/g,"&quot;")}
function fmt(ts){var d=new Date(ts*1000);return d.toLocaleTimeString("en-GB",{hour12:false,hour:"2-digit",minute:"2-digit",second:"2-digit"})}
function bodyText(b){if(typeof b==="object"&&b){var p=[];if(b.summary)p.push(b.summary);if(b.verdict)p.push("verdict: "+b.verdict);if(b.paths&&b.paths.length)p.push("paths:\\n  "+b.paths.join("\\n  "));return p.join("\\n")}return String(b||"")}
function typeClass(t){var ok=["task","progress","result","guidance","terminate","question"];return ok.indexOf(t)>=0?"t-"+t:"t-default"}
function makeEntry(msg){
  var div=document.createElement("div");
  var tc=typeClass(msg.type);
  div.className="entry "+tc;
  var body=bodyText(msg.body);
  var isLong=body.length>260;
  var from=msg.from||(msg._dir==="in"?"advisor":"worker");
  var bc="badge"+(msg.type==="progress"?" badge-progress":msg.type==="result"?" badge-result":"");
  div.innerHTML=
    "<div class=\\"entry-time\\">"+esc(fmt(msg.ts))+"</div>"
    +"<div class=\\"entry-dot\\"></div>"
    +"<div class=\\"card\\">"
      +"<div class=\\"card-head\\">"
        +"<span class=\\""+bc+"\\">"+esc(msg.type)+"</span>"
        +"<span class=\\"from\\">"+esc(from)+"</span>"
        +"<span class=\\"seq\\">#"+esc(msg.seq)+"</span>"
      +"</div>"
      +"<div class=\\"body-text"+(isLong?" long":"")+"\\">"+esc(body)+"</div>"
    +"</div>";
  var bodyEl=div.querySelector(".body-text");
  bodyEl.onclick=function(){this.classList.toggle("open");this.classList.remove("long");};
  return div;
}
function renderTimeline(msgs){
  var tl=document.getElementById("timeline");
  tl.innerHTML="";
  if(!msgs.length){tl.innerHTML="<div class=\\"empty\\"><div class=\\"icon\\">&#128237;</div>No messages yet</div>";return;}
  var line=document.createElement("div");line.className="tl-line";tl.appendChild(line);
  for(var i=0;i<msgs.length;i++)tl.appendChild(makeEntry(msgs[i]));
}
function appendEntries(msgs){
  var tl=document.getElementById("timeline");
  if(tl.querySelector(".empty")){tl.innerHTML="";var line=document.createElement("div");line.className="tl-line";tl.appendChild(line);}
  for(var i=0;i<msgs.length;i++)tl.appendChild(makeEntry(msgs[i]));
  tl.parentElement.scrollTop=tl.parentElement.scrollHeight;
}
function init(){
  fetch("/api/sessions/"+encodeURIComponent(SID)+"/messages")
    .then(function(r){return r.json();})
    .then(function(msgs){
      renderTimeline(msgs);
      var maxSeq=msgs.length?Math.max.apply(null,msgs.map(function(m){return m.seq||0;})):0;
      var url="/events?sid="+encodeURIComponent(SID)+"&after="+maxSeq;
      evtSrc=new EventSource(url);
      evtSrc.onopen=function(){
        document.getElementById("liveDot").className="live-dot on";
        document.getElementById("liveLabel").textContent="live";
      };
      evtSrc.onmessage=function(e){
        try{var ev=JSON.parse(e.data);if(ev.event==="messages")appendEntries(ev.msgs);}catch(_){}
      };
      evtSrc.onerror=function(){
        document.getElementById("liveDot").className="live-dot";
        document.getElementById("liveLabel").textContent="reconnecting&#8230;";
      };
    });
}
init();
</script>
</body>
</html>`;
}

