#!/usr/bin/env node

const path = require('path');

function parseArgs(argv) {
  const args = {};
  for (let i = 2; i < argv.length; i++) {
    if (argv[i] === '--task-type') {
      args['--task-type'] = argv[++i];
    } else if (argv[i] === '--repo') {
      args['--repo'] = argv[++i];
    } else if (argv[i] === '--dry-run') {
      args['--dry-run'] = true;
    }
  }
  return args;
}

async function main() {
  const argv = parseArgs(process.argv);
  const taskType = argv['--task-type'];
  const repoRoot = argv['--repo'] || process.cwd();
  const dryRun = argv['--dry-run'] || process.env.ADVISOR_DRY_RUN === '1';

  // Load raw pipeline JSON synchronously (avoids ESM dynamic import for Node compat).
  const filePath = path.join(repoRoot, 'pipelines', `${taskType}.json`);
  let pipeline;
  try {
    pipeline = JSON.parse(require('fs').readFileSync(filePath, 'utf8'));
  } catch {
    pipeline = null;
  }

  if (!pipeline) {
    process.stderr.write('no pipeline found\n');
    process.exit(1);
  }

  const { validatePipeline, runPipeline } = await import(path.join(__dirname, '../lib/pipeline.js'));
  validatePipeline(pipeline);

  if (dryRun) {
    const now = new Date().toISOString();
    const steps = pipeline.steps.map((step, i) => ({
      step_index: i,
      sid: 'dry-run-' + i,
      agent: step.agent,
      status: 'dry-run',
      summary: '(dry run — would substitute templates)',
      verdict: 'complete',
    }));
    const report = {
      name: pipeline.name,
      steps,
      startedAt: now,
      endedAt: now,
    };
    process.stdout.write(JSON.stringify(report) + '\n');
    process.exit(0);
  }

  const report = await runPipeline(pipeline, {});
  process.stdout.write(JSON.stringify(report) + '\n');
  process.exit(0);
}

main().catch((err) => {
  process.stderr.write((err.message || String(err)) + '\n');
  process.exit(1);
});
