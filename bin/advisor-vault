#!/usr/bin/env bun
// bin/advisor-vault — query the native vault index
// Usage:
//   advisor-vault search --text "prior art" [--limit 10]
//   advisor-vault backlinks --note "sessions/1777631574-208ed7"
//   advisor-vault path

import { searchNotes, backlinks, listDue, listUnresolved, vaultRoot, rebuildIndex, deleteNote, previewDeleteNote, listHubs, listGaps, backfillVerdicts, retroLink, computeCommunities, listCommunities, embedNotes } from '../lib/vault.js';

const args = process.argv.slice(2);
const cmd = args[0];

function getFlag(flag, fallback) {
  const idx = args.indexOf(flag);
  return idx !== -1 ? args[idx + 1] : fallback;
}

if (cmd === 'search') {
  const text = getFlag('--text', args[1]);
  const limit = parseInt(getFlag('--limit', '10'), 10);
  if (!text) { console.error('Usage: advisor-vault search --text <query> [--limit N]'); process.exit(1); }
  const results = searchNotes(text, limit);
  if (!results.length) { console.log('No results.'); process.exit(0); }
  for (const r of results) {
    console.log(`${r.path}  [${r.type}] ${r.created_at}`);
    console.log(`  ${r.snippet}`);
  }
} else if (cmd === 'backlinks') {
  const note = getFlag('--note', args[1]);
  if (!note) { console.error('Usage: advisor-vault backlinks --note <name>'); process.exit(1); }
  const bl = backlinks(note);
  console.log(bl.length ? bl.join('\n') : '(no backlinks)');
} else if (cmd === 'path') {
  console.log(vaultRoot());
} else if (cmd === 'due') {
  const today = new Date().toISOString().slice(0, 10);
  const window = parseInt(getFlag('--window', '14'), 10);
  const rows = listDue(today, window);
  if (!rows.length) { console.log('(no due reminders)'); process.exit(0); }
  for (const r of rows) {
    const preview = (r.established || r.body || '').replace(/\n/g, ' ').slice(0, 80);
    console.log(`${r.due_date}  ${r.path} — ${preview}`);
  }
} else if (cmd === 'unresolved') {
  const rows = listUnresolved();
  if (!rows.length) { console.log('(no unresolved links)'); process.exit(0); }
  for (const r of rows) {
    console.log(`${r.source} -> ${r.target}`);
  }
} else if (cmd === 'rebuild') {
  const doEmbed = args.includes('--embed');
  const embedThreshold = parseFloat(getFlag('--embed-threshold', '0.75'));
  const { indexed, communities } = rebuildIndex();
  let msg = `Indexed ${indexed} note(s).`;
  if (doEmbed) {
    const es = await embedNotes({ threshold: embedThreshold, onlyChanged: true });
    msg += ` Embedded ${es.embedded} / skipped-hash ${es.skipped_hash}. Semantic links added: ${es.semantic_links_added}.`;
    // Recompute communities so they reflect new semantic edges
    const commResult2 = computeCommunities();
    msg += ` Communities: ${commResult2.communities} across ${commResult2.nodes} nodes (modularity=${commResult2.modularity}).`;
  } else if (communities) {
    msg += ` Communities: ${communities.communities} across ${communities.nodes} nodes (modularity=${communities.modularity}).`;
  }
  console.log(msg);
} else if (cmd === 'embed') {
  const limit = parseInt(getFlag('--limit', '0'), 10);
  const threshold = parseFloat(getFlag('--threshold', '0.75'));
  const force = args.includes('--force');
  console.log(`Embedding vault notes (threshold=${threshold}${limit ? `, limit=${limit}` : ''})...`);
  const result = await embedNotes({ limit, threshold, force });
  console.log(`Embedded: ${result.embedded}  Skipped-hash: ${result.skipped_hash}  Semantic links added: ${result.semantic_links_added}  Skipped-existing: ${result.semantic_links_skipped_existing}`);
} else if (cmd === 'delete') {
  const note = getFlag('--note', null);
  if (!note) { console.error('Usage: advisor-vault delete --note <relpath> [--dry-run]'); process.exit(1); }
  const dryRun = args.includes('--dry-run');
  if (dryRun) {
    const { absPath, exists, links } = previewDeleteNote(note);
    console.log(`Would delete: ${absPath}`);
    if (links.length) {
      console.log('Link rows to remove:');
      for (const l of links) console.log(`  ${l.source} -> ${l.target}`);
    } else {
      console.log('(no link rows)');
    }
  } else {
    const { deleted } = deleteNote(note);
    console.log(deleted ? `Deleted: ${note}` : `Not found: ${note}`);
  }
} else if (cmd === 'hubs') {
  const limit = parseInt(getFlag('--limit', '20'), 10);
  const rows = listHubs(limit);
  if (!rows.length) { console.log('(no hubs)'); process.exit(0); }
  for (const r of rows) {
    console.log(`${r.target}  deg=${r.deg}`);
  }
} else if (cmd === 'gaps') {
  const limit = parseInt(getFlag('--limit', '20'), 10);
  const rows = listGaps(limit);
  if (!rows.length) { console.log('(no gaps)'); process.exit(0); }
  for (const r of rows) {
    const preview = (r.established || '').replace(/\n/g, ' ').slice(0, 80);
    console.log(`${r.sid}  ${r.path} — ${preview}`);
  }
} else if (cmd === 'backfill-verdicts') {
  const dryRun = args.includes('--dry-run');
  const { total, backfilled, skippedLegacy, skippedMissing, report } = backfillVerdicts(dryRun);
  console.log(`Candidates: ${total}  Backfilled: ${backfilled}  Skipped-legacy: ${skippedLegacy}  Skipped-missing: ${skippedMissing}${dryRun ? '  [dry-run]' : ''}`);
  for (const r of report) {
    if (r.status === 'would-set' || r.status === 'set') {
      console.log(`  ${r.sid}  ${r.path}  verdict=${r.verdict}`);
    }
  }
} else if (cmd === 'retro-link') {
  const dryRun = args.includes('--dry-run');
  const limit = parseInt(getFlag('--limit', '0'), 10);
  const { candidates, rewritten, skippedNoSids, skippedHasSection } = retroLink({ dryRun, limit });
  console.log(`Candidates: ${candidates}  Rewritten: ${rewritten}  Skipped-no-sids: ${skippedNoSids}  Skipped-has-section: ${skippedHasSection}${dryRun ? '  [dry-run]' : ''}`);
} else if (cmd === 'communities') {
  const recompute = args.includes('--recompute');
  const limit = parseInt(getFlag('--limit', '20'), 10);
  if (recompute) {
    const { communities, nodes, modularity } = computeCommunities();
    console.log(`Computed: ${communities} communities across ${nodes} nodes  modularity=${modularity}`);
  }
  const rows = listCommunities(limit);
  if (!rows.length) { console.log('(no communities — run with --recompute first)'); process.exit(0); }
  for (const r of rows) {
    const memberArr = Array.isArray(r.members) ? r.members : r.members.split(', ').filter(Boolean);
    const sample = memberArr.slice(0, 5).join(', ');
    console.log(`community=${r.community_id}  size=${r.size}  members: ${sample}${r.size > 5 ? ', ...' : ''}`);
    if (r.representative_titles) {
      const titles = r.representative_titles.filter(Boolean);
      if (titles.length) console.log(`  titles: ${titles.join(' | ').slice(0, 80)}`);
    }
  }
} else {
  console.error('Usage: advisor-vault <search|backlinks|path|due|unresolved|rebuild|embed|delete|hubs|gaps|backfill-verdicts|retro-link|communities> [options]');
  process.exit(1);
}
