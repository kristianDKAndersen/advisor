#!/usr/bin/env bash
# summon — provision a worker session. By default runs headless (no Terminal
# tab); pass --tui to open an interactive claude session in a new macOS tab.
#
# Usage:
#   bin/summon --agent <name> --task "<brief>" --goal "<done condition>" [--sid <id>]
#   bin/summon --tui   --agent <name> --task "<brief>" --goal "<done condition>"
#
# Prints the JSON metadata from lib/summon.js on stdout so the Advisor can parse it.

set -euo pipefail

AGENT=""
TASK=""
GOAL=""
SID=""
MODEL=""
INTELLIGENCE=""
ALLOWED_TOOLS=""
ENSEMBLE=""
MAX_TOOL_CALLS=""
# Default 15 min: long enough for planner/researcher passes; can be overridden
# with --timeout-sec. tmux-runner.js has a 300s safety net if this is unset,
# which is too aggressive for non-trivial work — hence the explicit default here.
TIMEOUT_SEC="1500"
REQUIRED_OUTPUT=""
TUI=""
NO_TIMELINE=""
SUB_TEAM=""
SUB_TEAM_MODEL=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --agent)          AGENT="$2";          shift 2 ;;
    --task)           TASK="$2";           shift 2 ;;
    --goal)           GOAL="$2";           shift 2 ;;
    --sid)            SID="$2";            shift 2 ;;
    --model)          MODEL="$2";          shift 2 ;;
    --intelligence)   INTELLIGENCE="$2";   shift 2 ;;
    --allowed-tools)  ALLOWED_TOOLS="$2";  shift 2 ;;
    --ensemble)       ENSEMBLE="$2";       shift 2 ;;
    --max-tool-calls) MAX_TOOL_CALLS="$2"; shift 2 ;;
    --timeout-sec)    TIMEOUT_SEC="$2";    shift 2 ;;
    --required-output) REQUIRED_OUTPUT="$2"; shift 2 ;;
    --tui)            TUI=1;               shift ;;
    --no-timeline)    NO_TIMELINE=1;       shift ;;
    --sub-team)       SUB_TEAM=1;          shift ;;
    --sub-team-model) SUB_TEAM_MODEL="$2"; shift 2 ;;
    -h|--help)
      echo "Usage: summon --agent <name> --task \"<brief>\" --goal \"<done>\" [--tui] [--no-timeline] [--sid <id>] [--model <model>] [--intelligence <0-100>] [--ensemble <n>] [--allowed-tools \"T1,T2\"] [--max-tool-calls <n>] [--timeout-sec <s>] [--required-output \"field1,field2\"] [--sub-team] [--sub-team-model sonnet|haiku|opus]"
      exit 0
      ;;
    *) echo "Unknown flag: $1" >&2; exit 1 ;;
  esac
done

if [[ -z "$AGENT" || -z "$TASK" || -z "$GOAL" ]]; then
  echo "Missing required flag. Run --help for usage." >&2
  exit 1
fi

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

# Provision workspace + channel + bootstrap prompt.
NODE_ARGS=(--agent "$AGENT" --task "$TASK" --goal "$GOAL")
[[ -n "$SID"            ]] && NODE_ARGS+=(--sid           "$SID")
[[ -n "$MODEL"          ]] && NODE_ARGS+=(--model         "$MODEL")
[[ -n "$INTELLIGENCE"   ]] && NODE_ARGS+=(--intelligence  "$INTELLIGENCE")
[[ -n "$ALLOWED_TOOLS"  ]] && NODE_ARGS+=(--allowedTools  "$ALLOWED_TOOLS")
[[ -n "$ENSEMBLE"       ]] && NODE_ARGS+=(--ensemble      "$ENSEMBLE")
[[ -n "$MAX_TOOL_CALLS" ]] && NODE_ARGS+=(--maxToolCalls  "$MAX_TOOL_CALLS")
[[ -n "$TIMEOUT_SEC"    ]] && NODE_ARGS+=(--timeoutSec    "$TIMEOUT_SEC")
[[ -n "$REQUIRED_OUTPUT" ]] && NODE_ARGS+=(--requiredOutput "$REQUIRED_OUTPUT")
[[ -n "$TUI"            ]] && NODE_ARGS+=(--tui)
[[ -n "$SUB_TEAM"       ]] && NODE_ARGS+=(--sub-team)
[[ -n "$SUB_TEAM_MODEL" ]] && NODE_ARGS+=(--sub-team-model "$SUB_TEAM_MODEL")
META=$(node "$ROOT/lib/summon.js" "${NODE_ARGS[@]}")

# Parse paths out of the JSON (node one-liner, no deps).
extract() { echo "$META" | node -e "console.log(JSON.parse(require('fs').readFileSync(0,'utf8')).$1)"; }
SID=$(extract sid)
LAUNCH_SH=$(extract launchScript)

if [[ -n "$TUI" ]]; then
  if [[ "${ADVISOR_TMUX_MULTIPLEX:-}" == "1" ]]; then
    # --tui tiled: all workers share one 'tui' window in the advisor session.
    # ensureTuiPane handles the spinlock, session setup, window-or-split,
    # pane tagging, and layout — prints the pane_id to stdout.
    SESSION_DIR="$(dirname "$LAUNCH_SH")"
    LOG_FILE="$SESSION_DIR/claude.log"
    PROMPT_FILE="$(extract promptFile)"
    TIMEOUT_MS=$((TIMEOUT_SEC * 1000))
    if ! PANE_ID=$(node "$ROOT/lib/tmux-runner.js" --ensure-tui-pane --sid "$SID"); then
      echo "[summon] ensureTuiPane failed for sid=$SID" >&2
      exit 1
    fi
    echo "[summon] --tui (tiled) — agent=$AGENT sid=$SID pane=$PANE_ID" >&2
    nohup env ADVISOR_TMUX_MULTIPLEX=1 node "$ROOT/lib/tmux-runner.js" \
      --sid "$SID" --agent "$AGENT" \
      --launch-script "$LAUNCH_SH" \
      --prompt-file "$PROMPT_FILE" \
      --log-file "$LOG_FILE" \
      --pane-id "$PANE_ID" \
      --timeout-ms "$TIMEOUT_MS" \
      >>"$SESSION_DIR/tmux-runner.log" 2>&1 & disown
    # Open Terminal only when no client is already attached to the advisor session.
    # An existing client already sees the new tiled pane — a second Terminal would
    # duplicate the view.
    CLIENT_COUNT=$(tmux list-clients -t advisor 2>/dev/null | wc -l | tr -d ' ')
    if [[ "${CLIENT_COUNT}" == "0" ]]; then
      if [[ "$(uname)" == "Darwin" ]] && command -v osascript >/dev/null 2>&1; then
        osascript \
          -e "set wasRunning to application \"Terminal\" is running" \
          -e "tell application \"Terminal\"" \
          -e "activate" \
          -e "if wasRunning then" \
          -e "do script \"tmux attach -t advisor \\\\; select-window -t tui\"" \
          -e "else" \
          -e "delay 0.2" \
          -e "do script \"tmux attach -t advisor \\\\; select-window -t tui\" in window 1" \
          -e "end if" \
          -e "end tell" >/dev/null
      else
        echo "[summon] run: tmux attach -t advisor \\; select-window -t tui" >&2
      fi
    fi
  else
    # Legacy --tui: open an interactive claude session in a new macOS Terminal tab.
    #
    # Wrap $LAUNCH_SH for safe embedding inside the do-script shell command.
    # The AppleScript string itself is double-quoted, but Terminal then re-parses
    # the contents as a shell command — so we need shell-level quoting around the
    # path to survive spaces. We also escape single quotes (rare but real, e.g.
    # /Users/O'Brien/...) using the standard '\'' bash trick.
    #
    # Window-handling note: if Terminal isn't already running, `activate` cold-launches it
    # and macOS auto-opens a blank window. A naked `do script` then opens a SECOND window,
    # leaving an empty terminal behind. We detect the cold-start case and reuse window 1.
    LAUNCH_SH_QUOTED="'${LAUNCH_SH//\'/\'\\\'\'}'"
    if [[ "$(uname)" == "Darwin" ]] && command -v osascript >/dev/null 2>&1; then
      osascript \
        -e "set wasRunning to application \"Terminal\" is running" \
        -e "tell application \"Terminal\"" \
        -e "activate" \
        -e "if wasRunning then" \
        -e "do script \"bash $LAUNCH_SH_QUOTED\"" \
        -e "else" \
        -e "delay 0.2" \
        -e "do script \"bash $LAUNCH_SH_QUOTED\" in window 1" \
        -e "end if" \
        -e "end tell" >/dev/null
      echo "[summon] opened Terminal tab — agent=$AGENT sid=$SID" >&2
    else
      echo "[summon] non-macOS or no osascript. Run this in a new terminal:" >&2
      echo "  bash $LAUNCH_SH_QUOTED" >&2
    fi
  fi
else
  # Headless mode (default): run via tmux+Stop-hook; blocks until claude finishes.
  SESSION_DIR="$(dirname "$LAUNCH_SH")"
  LOG_FILE="$SESSION_DIR/claude.log"
  PROMPT_FILE="$(extract promptFile)"
  echo "[summon] headless — agent=$AGENT sid=$SID log=$LOG_FILE" >&2

  # Auto-start the timeline server before blocking on tmux-runner.
  # Reads ADVISOR_TIMELINE_PORT env var; defaults to 7878.
  TIMELINE_PORT="${ADVISOR_TIMELINE_PORT:-7878}"
  if [[ -z "$NO_TIMELINE" ]]; then
    if ! curl -sf --connect-timeout 1 "http://127.0.0.1:$TIMELINE_PORT/health" >/dev/null 2>&1; then
      mkdir -p "$HOME/.advisor"
      nohup node "$ROOT/bin/advisor-timeline" --port "$TIMELINE_PORT" >>"$HOME/.advisor/timeline.log" 2>&1 &
      disown
    fi
    TIMELINE_URL="http://127.0.0.1:$TIMELINE_PORT/session/$SID"
    echo "$TIMELINE_URL"
    if [[ "$(uname)" == "Darwin" ]]; then
      open "$TIMELINE_URL" 2>/dev/null || true
    else
      xdg-open "$TIMELINE_URL" 2>/dev/null || true
    fi
  fi

  TIMEOUT_MS=$((TIMEOUT_SEC * 1000))

  if [[ "${ADVISOR_TMUX_MULTIPLEX:-}" == "1" && -n "$ENSEMBLE" ]]; then
    # ENSEMBLE + MULTIPLEX: orchestrate window+panes in bin/summon, pass --pane-id per worker.
    N_SESSIONS=$(echo "$META" | node -e "const m=JSON.parse(require('fs').readFileSync(0,'utf8')); console.log(m.sessions ? m.sessions.length : 1);")
    SID_SHORT_TS="$(date +%Y%m%d)"
    WIN_NAME="ensemble-${N_SESSIONS}-${SID_SHORT_TS}"

    tmux new-session -d -s advisor -x 220 -y 50 -n __advisor_scratch__ 2>/dev/null || tmux has-session -t advisor

    FIRST=$(tmux new-window -d -t advisor -n "$WIN_NAME" -P -F '#{window_id}:#{pane_id}')
    WIN_ID="${FIRST%%:*}"
    PANE_IDS=("${FIRST##*:}")

    tmux kill-window -t 'advisor:__advisor_scratch__' 2>/dev/null || true

    for i in $(seq 1 $((N_SESSIONS - 1))); do
      pid=$(tmux split-window -d -t "advisor:${WIN_ID}" -P -F '#{pane_id}')
      PANE_IDS+=("$pid")
    done

    tmux select-layout -t "advisor:${WIN_ID}" tiled

    for i in $(seq 0 $((N_SESSIONS - 1))); do
      SID_i=$(echo "$META" | node -e "const m=JSON.parse(require('fs').readFileSync(0,'utf8')); console.log(m.sessions[$i].sid);")
      LAUNCH_i=$(echo "$META" | node -e "const m=JSON.parse(require('fs').readFileSync(0,'utf8')); console.log(m.sessions[$i].launchScript);")
      PROMPT_i=$(echo "$META" | node -e "const m=JSON.parse(require('fs').readFileSync(0,'utf8')); console.log(m.sessions[$i].promptFile);")
      SESSION_DIR_i="$(dirname "$LAUNCH_i")"
      LOG_i="$SESSION_DIR_i/claude.log"
      nohup env ADVISOR_TMUX_MULTIPLEX=1 node "$ROOT/lib/tmux-runner.js" \
        --sid "$SID_i" --agent "$AGENT" \
        --launch-script "$LAUNCH_i" \
        --prompt-file "$PROMPT_i" \
        --log-file "$LOG_i" \
        --pane-id "${PANE_IDS[$i]}" \
        --timeout-ms "$TIMEOUT_MS" \
        >> "$SESSION_DIR_i/tmux-runner.log" 2>&1 & disown
    done
  else
    # Solo headless (or non-multiplex): forward ADVISOR_TMUX_MULTIPLEX into the runner process.
    nohup env ADVISOR_TMUX_MULTIPLEX="${ADVISOR_TMUX_MULTIPLEX:-}" node "$ROOT/lib/tmux-runner.js" \
      --sid "$SID" --agent "$AGENT" \
      --launch-script "$LAUNCH_SH" \
      --prompt-file "$PROMPT_FILE" \
      --log-file "$LOG_FILE" \
      --timeout-ms "$TIMEOUT_MS" \
      >>"$SESSION_DIR/tmux-runner.log" 2>&1 & disown
  fi
fi

# Emit the full JSON on stdout for the Advisor to consume.
echo "$META"
