{
  "agent": "coder",
  "model": "sonnet",
  "env": {
    "CLAUDE_CODE_SUBAGENT_MODEL": "haiku",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "ADVISOR_WORKER_HOOKS": "0"
  },
  "permissions": {
    "allow": [
      "Read",
      "Edit",
      "Write",
      "Grep",
      "Glob",
      "Bash(node *)",
      "Bash(bash *)",
      "Bash(ls *)",
      "Bash(git diff*)",
      "Bash(git status*)",
      "Bash(git log*)",
      "Bash(python3 *)",
      "Bash(mkdir *)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node $ADV/lib/hooks/worker-trace.js"
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash $ADV/lib/hooks/worker-inbox-poll.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash $ADV/lib/hooks/worker-auto-close.sh"
          }
        ]
      }
    ]
  }
}
