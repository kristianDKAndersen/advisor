{
  "agent": "deep-researcher",
  "model": "sonnet",
  "env": {
    "CLAUDE_CODE_SUBAGENT_MODEL": "sonnet",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": [
      "Read",
      "Write",
      "Grep",
      "Glob",
      "WebSearch",
      "WebFetch",
      "Skill",
      "Task",
      "Bash(bash *)",
      "Bash(ls *)",
      "Bash(mkdir *)",
      "Bash(find *)",
      "Bash(bun *)",
      "Bash(echo *)"
    ]
  }
}
