{
  "agent": "deep-researcher",
  "model": "sonnet",
  "env": {
    "CLAUDE_CODE_SUBAGENT_MODEL": "sonnet",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "ADVISOR_WORKER_HOOKS": "0"
  },
  "permissions": {
    "allow": [
      "Read",
      "Write",
      "Grep",
      "Glob",
      "WebSearch",
      "WebFetch",
      "Skill",
      "Task",
      "Bash(bash *)",
      "Bash(ls *)",
      "Bash(mkdir *)",
      "Bash(find *)",
      "Bash(bun *)",
      "Bash(echo *)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node $ADV/lib/hooks/worker-trace.js"
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash $ADV/lib/hooks/worker-inbox-poll.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash $ADV/lib/hooks/worker-auto-close.sh"
          }
        ]
      }
    ]
  }
}
