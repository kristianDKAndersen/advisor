{
  "agent": "creative",
  "model": "sonnet",
  "env": {
    "CLAUDE_CODE_SUBAGENT_MODEL": "haiku",
     "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": [
      "Read",
      "Write",
      "Grep",
      "Glob",
      "Skill",
      "Task",
      "Bash(bash *)",
      "Bash(ls *)",
      "Bash(python3 *)",
      "Bash(mkdir *)"
    ]
  }
}
