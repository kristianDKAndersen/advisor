{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "",
        "hooks": [{"type": "command", "command": "node $ADV/lib/hooks/worker-trace.js"}]
      },
      {
        "matcher": "",
        "hooks": [{"type": "command", "command": "bash $ADV/lib/hooks/worker-inbox-poll.sh"}]
      },
      {
        "matcher": "Bash",
        "hooks": [{"type": "command", "command": "bash $ADV/lib/hooks/worker-auto-close.sh"}]
      }
    ]
  },
  "env": {
    "ADVISOR_WORKER_HOOKS": "0"
  }
}
