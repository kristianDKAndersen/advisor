{
  "agent": "researcher",
  "model": "sonnet",
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": [
      "Read",
      "Write",
      "Edit",
      "Grep",
      "Glob",
      "WebSearch",
      "WebFetch",
      "Bash(node *)",
      "Bash(bash *)",
      "Bash(node ~/dev/devtest/ccchat-improve/scripts/chat-send.js:*)",
      "Bash(node ~/dev/devtest/ccchat-improve/scripts/chat-read.js:*)",
      "Bash(node ~/dev/devtest/ccchat-improve/scripts/chat-ask.js:*)",
      "Bash(node ~/dev/devtest/ccchat-improve/scripts/chat-history.js:*)",
      "Bash(node ~/dev/devtest/ccchat-improve/scripts/chat-search.js:*)",
      "Bash(node ~/dev/devtest/ccchat-improve/scripts/chat-join.js:*)",
      "Bash(node ~/dev/devtest/ccchat-improve/scripts/chat-leave.js:*)",
      "Bash(node ~/dev/devtest/ccchat-improve/scripts/chat-pin.js:*)",
      "Bash(node ~/dev/devtest/ccchat-improve/scripts/chat-plan.js:*)",
      "Bash(node ~/dev/devtest/ccchat-improve/scripts/chat-claim.js:*)",
      "Bash(node ~/dev/devtest/ccchat-improve/scripts/chat-preclaim.js:*)",
      "Bash(node ~/dev/devtest/ccchat-improve/scripts/chat-catchup.js:*)",
      "Bash(node ~/dev/devtest/ccchat-improve/scripts/chat-watch.js:*)",
      "Bash(node ~/dev/devtest/ccchat-improve/scripts/chat-dashboard.js:*)",
      "Bash(node ~/dev/devtest/ccchat-improve/scripts/status.js:*)",
      "Bash(node ~/dev/devtest/ccchat-improve/scripts/session-bootstrap.js:*)",
      "Bash(node ~/dev/devtest/ccchat-improve/scripts/chat-digest.js:*)",
      "Bash(node ~/dev/devtest/ccchat-improve/scripts/chat-consensus.js:*)",
      "Bash(node ~/dev/devtest/ccchat-improve/scripts/chat-phase.js:*)",
      "Bash(node ~/dev/devtest/ccchat-improve/scripts/chat-ui.js:*)",
      "Bash(node ~/dev/devtest/ccchat-improve/scripts/chat-task-legacy.js:*)",
      "Bash(node ~/dev/devtest/ccchat-improve/scripts/adr-logger.js:*)",
      "Bash(node ~/dev/devtest/ccchat-improve/scripts/setup.js:*)",
      "Bash(pgrep -f:*)",
      "Bash(pkill -f \"chat-watch.js:*)"
    ]
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ~/dev/devtest/ccchat-improve/hooks/poll.js"
          },
          {
            "type": "command",
            "command": "node ~/dev/devtest/ccchat-improve/hooks/empty-project.js"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ~/dev/devtest/ccchat-improve/hooks/stop.js"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ~/dev/devtest/ccchat-improve/hooks/start.js"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ~/dev/devtest/ccchat-improve/hooks/leave.js"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ~/dev/devtest/ccchat-improve/hooks/notify.js"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/dev/devtest/ccchat-improve/scripts/statusline.sh"
  }
}
